<% layout('layouts/boilerplate') -%>

<!-- SideNavBar and Mobile TopBar (Partials) - Hidden on Print -->
<div class="print:hidden">
    <%- include('partials/sidebar') %>
</div>

<!-- Custom Print Styling Embedded for Direct Action -->
<style>
    @media print {
        body {
            background: #ffffff !important;
            color: #000000 !important;
            font-size: 12pt !important;
            overflow: visible !important;
            position: relative !important;
            height: auto !important;
        }
        main {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            overflow: visible !important;
        }
        .print-full-width {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        .glass-card {
            background: #ffffff !important;
            border: 1px solid #e2e8f0 !important;
            box-shadow: none !important;
            backdrop-filter: none !important;
            -webkit-backdrop-filter: none !important;
            border-radius: 8px !important;
            margin-bottom: 20px !important;
            page-break-inside: avoid !important;
        }
        .text-on-background, .text-on-surface, h1, h2, h3 {
            color: #000000 !important;
        }
        .text-on-surface-variant {
            color: #4a5568 !important;
        }
        .print:hidden, .ambient-orb {
            display: none !important;
        }
        .badge-print {
            border: 1px solid #cbd5e0 !important;
            background: #f7fafc !important;
            color: #2d3748 !important;
        }
        table {
            page-break-inside: auto;
        }
        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }
        thead {
            display: table-header-group;
        }
    }
</style>

<div class="flex h-screen overflow-hidden w-full print:block print:h-auto">
    <!-- Main Content -->
    <main class="flex-grow ml-0 md:ml-64 pt-24 md:pt-8 pb-24 px-margin-mobile md:px-container-padding max-w-[1440px] mx-auto overflow-y-auto relative print:m-0 print:p-0 print:w-full print:max-w-full">
        
        <div class="print-full-width w-full">
            <!-- Page Header / Control Row -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-section-gap gap-4 print:mb-8 md:pr-44">
                <div>
                    <h1 class="font-display-lg text-display-lg text-on-background mb-2">Monthly Executive Report</h1>
                    <p class="font-body-lg text-body-lg text-on-surface-variant">Aggregated financial metrics, security assessments, and ledger details for <%= currentMonthName %> <%= currentYear %>.</p>
                </div>
                
                <!-- Action Controls (Hidden on Print) -->
                <div class="print:hidden flex items-center gap-3">
                    <!-- Theme Toggle Pill -->
                    <button onclick="toggleTheme()" class="theme-toggle-pill relative flex items-center w-[56px] h-[28px] rounded-full cursor-pointer transition-all duration-300" style="background: rgba(141, 113, 104, 0.15);" title="Toggle Dark/Light Mode" type="button">
                        <span class="sun-icon absolute left-[6px] material-symbols-outlined text-[14px] text-amber-500 transition-opacity duration-300" style="font-variation-settings: 'FILL' 1;">light_mode</span>
                        <span class="moon-icon absolute right-[6px] material-symbols-outlined text-[14px] text-orange-300 transition-opacity duration-300" style="font-variation-settings: 'FILL' 1;">dark_mode</span>
                        <span class="theme-knob absolute left-[3px] w-[22px] h-[22px] rounded-full bg-white shadow-md transition-transform duration-300"></span>
                    </button>

                    <button onclick="window.print()" class="btn-primary text-white font-semibold rounded-lg px-6 py-3 flex items-center gap-2 hover:shadow-lg transition-all active:translate-y-0.5">
                        <span class="material-symbols-outlined text-[20px]">picture_as_pdf</span>
                        Export PDF / Print
                    </button>
                </div>
            </div>

            <!-- Dashboard Row 1: Executive KPI Panel -->
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-gutter mb-section-gap print:grid-cols-5 print:mb-8">
                <!-- Inflow Card -->
                <div class="glass-card rounded-xl p-6 hover-lift">
                    <span class="text-xs text-on-surface-variant uppercase font-bold tracking-wider block mb-2">Total Inflow</span>
                    <h3 class="text-xl sm:text-2xl md:text-3xl lg:text-lg xl:text-xl 2xl:text-2xl text-green-500 font-bold tracking-tight flex items-baseline">
                        <span class="text-primary font-bold mr-0.5 text-base sm:text-lg md:text-xl lg:text-sm xl:text-base 2xl:text-lg">$</span>
                        <%= totalIncome.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </h3>
                </div>

                <!-- Outflow Card -->
                <div class="glass-card rounded-xl p-6 hover-lift">
                    <span class="text-xs text-on-surface-variant uppercase font-bold tracking-wider block mb-2">Total Outflow</span>
                    <h3 class="text-xl sm:text-2xl md:text-3xl lg:text-lg xl:text-xl 2xl:text-2xl text-coral font-bold tracking-tight flex items-baseline print:text-black">
                        <span class="text-primary font-bold mr-0.5 text-base sm:text-lg md:text-xl lg:text-sm xl:text-base 2xl:text-lg">$</span>
                        <%= totalExpense.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </h3>
                </div>

                <!-- Net Flow Card -->
                <div class="glass-card rounded-xl p-6 hover-lift">
                    <span class="text-xs text-on-surface-variant uppercase font-bold tracking-wider block mb-2">Net Flow</span>
                    <h3 class="text-xl sm:text-2xl md:text-3xl lg:text-lg xl:text-xl 2xl:text-2xl <%= netSavings >= 0 ? 'text-green-500' : 'text-error' %> font-bold tracking-tight flex items-baseline print:text-black">
                        <% if (netSavings < 0) { %>
                            <span class="text-error font-bold mr-0.5 text-base sm:text-lg md:text-xl lg:text-sm xl:text-base 2xl:text-lg">-</span>
                        <% } %>
                        <span class="text-primary font-bold mr-0.5 text-base sm:text-lg md:text-xl lg:text-sm xl:text-base 2xl:text-lg">$</span>
                        <%= Math.abs(netSavings).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </h3>
                </div>

                <!-- Total Saved Card -->
                <div class="glass-card rounded-xl p-6 hover-lift">
                    <span class="text-xs text-on-surface-variant uppercase font-bold tracking-wider block mb-2">Total Saved</span>
                    <h3 class="text-xl sm:text-2xl md:text-3xl lg:text-lg xl:text-xl 2xl:text-2xl text-on-background font-bold tracking-tight flex items-baseline print:text-black">
                        <span class="text-primary font-bold mr-0.5 text-base sm:text-lg md:text-xl lg:text-sm xl:text-base 2xl:text-lg">$</span>
                        <%= typeof totalSavedAmount !== 'undefined' ? totalSavedAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0.00' %>
                    </h3>
                </div>

                <!-- Financial Health Card -->
                <div class="glass-card rounded-xl p-6 hover-lift">
                    <span class="text-xs text-on-surface-variant uppercase font-bold tracking-wider block mb-2">AI Health Rating</span>
                    <h3 class="text-xl sm:text-2xl md:text-3xl lg:text-lg xl:text-xl 2xl:text-2xl text-on-background font-bold tracking-tight flex items-baseline print:text-black">
                        <%= healthScore %><span class="text-xs text-on-surface-variant font-normal ml-0.5">/100</span>
                    </h3>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter print:block">
                <!-- Left: Budget Compliance Review -->
                <div class="lg:col-span-6 flex flex-col gap-gutter print:w-full print:mb-8">
                    <div class="glass-card rounded-xl p-6 hover-lift">
                        <h2 class="font-title-md text-title-md text-on-surface mb-6 flex items-center gap-2 border-b border-outline-variant/10 pb-4">
                            <span class="material-symbols-outlined text-primary">analytics</span>
                            Budget Compliance Audit
                        </h2>

                        <% if (typeof budgetSummaries === 'undefined' || budgetSummaries.length === 0) { %>
                            <p class="text-on-surface-variant text-center py-6 font-body-lg">No budget targets were set for this period.</p>
                        <% } else { %>
                            <div class="flex flex-col gap-6">
                                <% budgetSummaries.forEach(budget => { %>
                                    <div>
                                        <div class="flex justify-between items-center text-sm font-semibold mb-2">
                                            <span class="text-on-surface font-semibold"><%= budget.category %></span>
                                            <span class="<%= budget.isOver ? 'text-error font-bold' : 'text-on-surface-variant' %>">
                                                $<%= Math.round(budget.spent).toLocaleString() %> / $<%= Math.round(budget.limitAmount).toLocaleString() %> 
                                                (<%= budget.percentUsed %>%)
                                            </span>
                                        </div>
                                        <div class="w-full bg-surface-container rounded-full h-2.5 overflow-hidden">
                                            <div class="h-full rounded-full transition-all <%= budget.percentUsed >= 100 ? 'bg-error' : budget.percentUsed >= 80 ? 'bg-warning' : 'bg-green-500' %>" style="width: <%= Math.min(100, budget.percentUsed) %>%"></div>
                                        </div>
                                        <% if (budget.isOver) { %>
                                            <p class="text-xs text-error mt-1 flex items-center gap-1 font-semibold">
                                                <span class="material-symbols-outlined text-[14px]">warning</span>
                                                Overrun by $<%= Math.round(budget.spent - budget.limitAmount).toLocaleString() %>!
                                            </p>
                                        <% } %>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Right: Security / Fraud Ledger -->
                <div class="lg:col-span-6 flex flex-col gap-gutter print:w-full">
                    <div class="glass-card rounded-xl p-6 hover-lift">
                        <h2 class="font-title-md text-title-md text-on-surface mb-6 flex items-center gap-2 border-b border-outline-variant/10 pb-4">
                            <span class="material-symbols-outlined text-secondary">security</span>
                            Security / Fraud Alert Ledger
                        </h2>

                        <% if (typeof securityAlerts === 'undefined' || securityAlerts.length === 0) { %>
                            <div class="py-12 text-center text-on-surface-variant flex flex-col items-center justify-center">
                                <span class="material-symbols-outlined text-green-500 text-[32px] mb-2">verified_user</span>
                                <p class="font-semibold text-green-600">All Systems Clear</p>
                                <p class="text-xs mt-1 text-on-surface-variant">No transaction anomalies detected during this month's review cycle.</p>
                            </div>
                        <% } else { %>
                            <div class="flex flex-col gap-4">
                                <% securityAlerts.forEach(alert => { %>
                                    <div class="p-4 rounded-lg bg-error-container/10 border border-error/20 flex flex-col gap-2 page-break-inside-avoid">
                                        <div class="flex justify-between items-start">
                                            <div>
                                                <span class="font-semibold text-on-surface block text-sm"><%= alert.description || 'Anonymous Merchant' %></span>
                                                <span class="text-xs text-on-surface-variant">
                                                    <%= new Date(alert.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %> • <%= alert.category %>
                                                </span>
                                            </div>
                                            <div class="text-right">
                                                <span class="font-bold text-error block text-sm">$<%= alert.amount.toLocaleString() %></span>
                                                <span class="text-[10px] bg-error-container text-error px-2 py-0.5 rounded font-bold uppercase tracking-wider badge-print">
                                                    Score: <%= Math.round(alert.fraudScore * 100) %>%
                                                </span>
                                            </div>
                                        </div>
                                        <div class="pt-2 border-t border-outline-variant/10">
                                            <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider block">ML Anomaly Reasons:</span>
                                            <ul class="list-disc pl-4 text-xs text-on-surface-variant mt-1 space-y-1">
                                                <% (alert.flagReasons || []).forEach(reason => { %>
                                                    <li><%= reason %></li>
                                                <% }) %>
                                            </ul>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Savings Goals Progress Section -->
            <div class="glass-card rounded-xl p-6 mt-gutter print:mt-8 page-break-inside-avoid hover-lift">
                <h2 class="font-title-md text-title-md text-on-surface mb-6 flex items-center gap-2 border-b border-outline-variant/10 pb-4">
                    <span class="material-symbols-outlined text-primary">savings</span>
                    Savings Goals Progress
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% if (typeof savingsGoals === 'undefined' || savingsGoals.length === 0) { %>
                        <div class="col-span-full text-center py-6">
                            <p class="text-on-surface-variant font-body-lg">No active savings goals found.</p>
                        </div>
                    <% } else { %>
                        <% savingsGoals.forEach(goal => { 
                            const percent = Math.min(100, Math.round((goal.currentAmount / goal.targetAmount) * 100));
                        %>
                            <div class="border border-outline-variant/20 rounded-lg p-4 bg-surface-container-lowest flex flex-col justify-between">
                                <div>
                                    <div class="flex justify-between items-center mb-2">
                                        <h4 class="font-semibold text-on-surface"><%= goal.title %></h4>
                                        <span class="text-xs font-bold <%= percent >= 100 ? 'text-green-600' : 'text-primary' %>"><%= percent %>%</span>
                                    </div>
                                    <div class="w-full bg-surface-container rounded-full h-2 overflow-hidden mb-2">
                                        <div class="h-full <%= percent >= 100 ? 'bg-green-500' : 'bg-primary' %> rounded-full" style="width: <%= percent %>%"></div>
                                    </div>
                                    <div class="flex justify-between text-xs text-on-surface-variant mb-2">
                                        <span>$<%= goal.currentAmount.toLocaleString() %> saved</span>
                                        <span>Goal: $<%= goal.targetAmount.toLocaleString() %></span>
                                    </div>
                                </div>
                                <% if (percent >= 100) { %>
                                    <div class="mt-2 text-[10px] font-bold text-green-600 uppercase tracking-wider text-center bg-green-500/10 py-1.5 rounded">
                                        Goal Achieved! 🏆
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <!-- Transaction Ledger Section (Bottom full table) -->
            <div class="glass-card rounded-xl p-6 mt-gutter print:mt-8 page-break-inside-avoid hover-lift">
                <h2 class="font-title-md text-title-md text-on-surface mb-6 flex items-center gap-2 border-b border-outline-variant/10 pb-4">
                    <span class="material-symbols-outlined text-primary">receipt_long</span>
                    Monthly Transaction Ledger
                </h2>

                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-outline-variant/20">
                                <th class="py-3 px-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Date</th>
                                <th class="py-3 px-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Description</th>
                                <th class="py-3 px-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Category</th>
                                <th class="py-3 px-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Type</th>
                                <th class="py-3 px-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-right">Amount</th>
                                <th class="py-3 px-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof monthlyTransactions === 'undefined' || monthlyTransactions.length === 0) { %>
                                <tr>
                                    <td colspan="6" class="py-8 text-center text-on-surface-variant font-body-lg">No records found for this period.</td>
                                </tr>
                            <% } else { %>
                                <% monthlyTransactions.forEach(t => { %>
                                    <tr class="border-b border-outline-variant/10 hover:bg-surface-container-low transition-colors">
                                        <td class="py-4 px-4 text-sm text-on-surface">
                                            <%= new Date(t.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) %>
                                        </td>
                                        <td class="py-4 px-4 text-sm text-on-surface font-semibold">
                                            <%= t.description || 'N/A' %>
                                        </td>
                                        <td class="py-4 px-4 text-sm text-on-surface-variant">
                                            <%= t.category %>
                                        </td>
                                        <td class="py-4 px-4 text-sm text-on-surface-variant capitalize">
                                            <%= t.type %>
                                        </td>
                                        <td class="py-4 px-4 text-sm font-bold text-right <%= t.type === 'income' ? 'text-green-600' : 'text-on-surface' %>">
                                            <%= t.type === 'income' ? '+' : '-' %>$<%= t.amount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                        </td>
                                        <td class="py-4 px-4 text-sm text-center">
                                            <% if (t.isFlagged) { %>
                                                <span class="px-2.5 py-1 rounded bg-error-container text-error text-xs font-bold uppercase tracking-wider badge-print">Flagged</span>
                                            <% } else { %>
                                                <span class="px-2.5 py-1 rounded bg-green-100 text-green-800 text-xs font-bold uppercase tracking-wider badge-print">Verified</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Footer Signature Box (Only visible on Print) -->
            <div class="hidden print:block mt-16 pt-8 border-t border-gray-300 text-center text-xs text-gray-500">
                <p>FraudGuard Automated Financial Statement • Built securely via Code-A-Thon Fintech</p>
                <p class="mt-1">Generated: <%= new Date().toLocaleString() %></p>
            </div>
        </div>
    </main>
</div>
