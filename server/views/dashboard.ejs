<% layout('layouts/boilerplate') -%>

<!-- SideNavBar and Mobile TopBar (Partials) -->
<%- include('partials/sidebar') %>

<div class="flex h-screen overflow-hidden w-full">
    <!-- Main Content -->
    <main class="flex-1 ml-0 md:ml-64 relative overflow-y-auto w-full">
        <div class="px-margin-mobile md:px-container-padding py-24 md:py-8 max-w-[1440px] mx-auto">
            <!-- Page Header -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-section-gap gap-4">
                <div>
                    <h2 class="font-headline-lg text-headline-lg text-on-background">Overview</h2>
                    <p class="text-on-surface-variant mt-1">Welcome back, <%= (typeof currentUser !== 'undefined' && currentUser.firstName) ? currentUser.firstName : 'User' %>! Real-time security insights.</p>
                </div>
                <div class="glass-card rounded-lg flex items-center px-4 py-2 cursor-pointer hover:bg-white/80 transition-colors shadow-[0_4px_12px_rgba(184,134,11,0.08)]">
                    <span class="material-symbols-outlined text-tertiary mr-2 text-[20px]">calendar_today</span>
                    <span class="font-label-md text-label-md text-on-surface mr-4">Last 30 Days</span>
                    <span class="material-symbols-outlined text-on-surface-variant text-[20px]">expand_more</span>
                </div>
            </div>

            <!-- KPI Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter mb-section-gap">
                <!-- Card 1: Total Processed Volume -->
                <div class="glass-card rounded-xl p-6 tilt-card group cursor-default" onmouseleave="resetTilt(this)" onmousemove="tilt(event, this)">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-full bg-primary-container/20 flex items-center justify-center text-primary-container">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">account_balance</span>
                        </div>
                        <span class="bg-surface-container px-2 py-1 rounded text-xs font-semibold text-secondary flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">trending_up</span>
                            +12.5%
                        </span>
                    </div>
                    <p class="text-on-surface-variant text-sm font-medium mb-1">Total Processed Volume</p>
                    <h3 class="font-display-lg text-display-lg text-on-background">
                        <%= (typeof totals !== 'undefined' && totals.processedVolume) ? totals.processedVolume : '$12.4M' %>
                    </h3>
                </div>

                <!-- Card 2: Flagged Transactions -->
                <div class="glass-card rounded-xl p-6 tilt-card group cursor-default" onmouseleave="resetTilt(this)" onmousemove="tilt(event, this)">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-full bg-secondary-container/20 flex items-center justify-center text-secondary-container">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">warning</span>
                        </div>
                        <span class="bg-error-container/50 px-2 py-1 rounded text-xs font-semibold text-error flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">trending_up</span>
                            +2.1%
                        </span>
                    </div>
                    <p class="text-on-surface-variant text-sm font-medium mb-1">Flagged Transactions</p>
                    <h3 class="font-display-lg text-display-lg text-on-background text-secondary">
                        <%= (typeof totals !== 'undefined' && totals.flaggedCount !== undefined) ? totals.flaggedCount : '243' %>
                    </h3>
                </div>

                <!-- Card 3: System Health Score -->
                <div class="glass-card rounded-xl p-6 tilt-card group cursor-default" onmouseleave="resetTilt(this)" onmousemove="tilt(event, this)">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-full bg-tertiary-container/20 flex items-center justify-center text-tertiary-container">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">health_and_safety</span>
                        </div>
                        <span class="bg-surface-container px-2 py-1 rounded text-xs font-semibold text-on-surface-variant">Stable</span>
                    </div>
                    <p class="text-on-surface-variant text-sm font-medium mb-1">System Health Score</p>
                    <h3 class="font-display-lg text-display-lg text-on-background">
                        <%= (typeof currentUser !== 'undefined' && currentUser.overallHealthScore) ? currentUser.overallHealthScore : '98.2' %><span class="text-xl text-outline font-normal">/100</span>
                    </h3>
                </div>

                <!-- Card 4: Prevented Losses -->
                <div class="glass-card rounded-xl p-6 tilt-card group cursor-default" onmouseleave="resetTilt(this)" onmousemove="tilt(event, this)">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">shield</span>
                        </div>
                        <span class="bg-surface-container px-2 py-1 rounded text-xs font-semibold text-tertiary flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">trending_down</span>
                            -0.5%
                        </span>
                    </div>
                    <p class="text-on-surface-variant text-sm font-medium mb-1">Prevented Losses</p>
                    <h3 class="font-display-lg text-display-lg text-on-background">
                        <%= (typeof totals !== 'undefined' && totals.preventedLosses) ? totals.preventedLosses : '$450K' %>
                    </h3>
                </div>
            </div>

            <!-- Main Grid Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
                <!-- Volume Chart (Static Representation matching Figma) -->
                <div class="lg:col-span-2 glass-card rounded-xl p-6 flex flex-col h-[450px]">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-title-md text-title-md text-on-background">Transaction Volume vs Prevented Risk</h3>
                        <button class="text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined">more_horiz</span>
                        </button>
                    </div>
                    <div class="flex-grow relative mt-4">
                        <div class="absolute inset-0 bar-chart-bg"></div>
                        <!-- Y-Axis Labels -->
                        <div class="absolute left-0 top-0 bottom-0 flex flex-col justify-between text-xs text-on-surface-variant z-10 w-8">
                            <span>10k</span>
                            <span>8k</span>
                            <span>6k</span>
                            <span>4k</span>
                            <span>2k</span>
                            <span>0</span>
                        </div>
                        <!-- Bars Container -->
                        <div class="absolute left-12 right-0 top-0 bottom-6 flex justify-around items-end z-10 pl-4">
                            <!-- Group 1 -->
                            <div class="flex gap-2 items-end h-full w-full justify-center group">
                                <div class="w-8 md:w-12 bg-primary-container/40 rounded-t-md h-[80%] hover:bg-primary-container/60 transition-all relative">
                                    <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-on-secondary-container text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">8.2k</div>
                                </div>
                                <div class="w-8 md:w-12 bg-primary rounded-t-md h-[30%] hover:bg-primary/80 transition-all"></div>
                            </div>
                            <!-- Group 2 -->
                            <div class="flex gap-2 items-end h-full w-full justify-center group">
                                <div class="w-8 md:w-12 bg-primary-container/40 rounded-t-md h-[60%] hover:bg-primary-container/60 transition-all"></div>
                                <div class="w-8 md:w-12 bg-primary rounded-t-md h-[25%] hover:bg-primary/80 transition-all"></div>
                            </div>
                            <!-- Group 3 -->
                            <div class="flex gap-2 items-end h-full w-full justify-center group">
                                <div class="w-8 md:w-12 bg-primary-container/40 rounded-t-md h-[90%] hover:bg-primary-container/60 transition-all"></div>
                                <div class="w-8 md:w-12 bg-primary rounded-t-md h-[40%] hover:bg-primary/80 transition-all"></div>
                            </div>
                            <!-- Group 4 -->
                            <div class="flex gap-2 items-end h-full w-full justify-center group">
                                <div class="w-8 md:w-12 bg-primary-container/40 rounded-t-md h-[70%] hover:bg-primary-container/60 transition-all"></div>
                                <div class="w-8 md:w-12 bg-primary rounded-t-md h-[20%] hover:bg-primary/80 transition-all"></div>
                            </div>
                        </div>
                        <!-- X-Axis Labels -->
                        <div class="absolute bottom-0 left-12 right-0 flex justify-around text-xs text-on-surface-variant font-medium pt-2 border-t border-outline-variant/30 font-bold">
                            <span>Week 1</span>
                            <span>Week 2</span>
                            <span>Week 3</span>
                            <span>Week 4</span>
                        </div>
                    </div>
                    <!-- Legend -->
                    <div class="flex gap-6 mt-6 justify-center">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-primary-container/40"></div>
                            <span class="text-sm text-on-surface-variant">Processed</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-primary"></div>
                            <span class="text-sm text-on-surface-variant">Prevented</span>
                        </div>
                    </div>
                </div>

                <!-- Risk Vectors List -->
                <div class="glass-card rounded-xl p-6 h-[450px] flex flex-col">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-title-md text-title-md text-on-background">Risk Vectors</h3>
                        <span class="material-symbols-outlined text-on-surface-variant text-[20px]">info</span>
                    </div>
                    <div class="flex-grow overflow-y-auto pr-2 space-y-6">
                        <!-- Vector 1 -->
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-secondary text-[20px]">lock_person</span>
                                    <span class="font-medium text-sm text-on-surface">Account Takeover</span>
                                </div>
                                <span class="font-bold text-sm text-on-background">45%</span>
                            </div>
                            <div class="w-full bg-surface-variant rounded-full h-2">
                                <div class="bg-secondary h-2 rounded-full" style="width: 45%"></div>
                            </div>
                        </div>
                        <!-- Vector 2 -->
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary-container text-[20px]">credit_card_off</span>
                                    <span class="font-medium text-sm text-on-surface">Payment Fraud</span>
                                </div>
                                <span class="font-bold text-sm text-on-background">30%</span>
                            </div>
                            <div class="w-full bg-surface-variant rounded-full h-2">
                                <div class="bg-primary-container h-2 rounded-full" style="width: 30%"></div>
                            </div>
                        </div>
                        <!-- Vector 3 -->
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-tertiary text-[20px]">masks</span>
                                    <span class="font-medium text-sm text-on-surface">Identity Spoofing</span>
                                </div>
                                <span class="font-bold text-sm text-on-background">15%</span>
                            </div>
                            <div class="w-full bg-surface-variant rounded-full h-2">
                                <div class="bg-tertiary h-2 rounded-full" style="width: 15%"></div>
                            </div>
                        </div>
                        <!-- Vector 4 -->
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-outline text-[20px]">more_horiz</span>
                                    <span class="font-medium text-sm text-on-surface">Other Threats</span>
                                </div>
                                <span class="font-bold text-sm text-on-background">10%</span>
                            </div>
                            <div class="w-full bg-surface-variant rounded-full h-2">
                                <div class="bg-outline h-2 rounded-full" style="width: 10%"></div>
                            </div>
                        </div>
                    </div>
                    <button class="mt-4 w-full py-2 border border-outline-variant rounded-lg text-primary font-label-md hover:bg-primary/5 transition-colors">
                        View Detailed Analysis
                    </button>
                </div>
            </div>
            
            <!-- Real-Time SSE Fraud Alerts Toast Container -->
            <div id="toast-container" class="fixed top-24 right-6 z-50 flex flex-col gap-3 w-80 pointer-events-none">
                <!-- Toasts are dynamically added here via sse.js -->
            </div>
        </div>
    </main>
</div>

<!-- Mobile Bottom NavBar (Partial) -->
<%- include('partials/mobile_nav') %>

<script>
    // Lightweight 3D Tilt Effect for cards
    function tilt(event, element) {
        if (!window.matchMedia("(pointer: fine)").matches) return;
        const rect = element.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateX = ((y - centerY) / centerY) * -5; // Max 5deg tilt
        const rotateY = ((x - centerX) / centerX) * 5;
        
        element.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
    }

    function resetTilt(element) {
        element.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
    }

    // Dynamic Orb movements
    document.addEventListener('mousemove', (e) => {
        const orbs = document.querySelectorAll('.ambient-orb');
        if (orbs.length >= 2) {
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            orbs[0].style.transform = `translate(${x * 20}px, ${y * 20}px)`;
            orbs[1].style.transform = `translate(${x * -30}px, ${y * -30}px)`;
        }
    });

    // Real-Time Fraud Alert Toast Renderer
    function showFraudToast(data) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = "pointer-events-auto bg-gradient-to-br from-secondary to-[#da3339] text-white p-5 rounded-2xl shadow-[0_8px_32px_rgba(182,21,36,0.3)] border border-white/20 slide-in transform transition-all duration-300 flex flex-col gap-2 relative overflow-hidden";
        
        toast.innerHTML = `
            <div class="absolute top-0 right-0 p-4 opacity-10">
                <span class="material-symbols-outlined text-6xl">warning</span>
            </div>
            <div class="flex items-center gap-2 relative z-10">
                <span class="material-symbols-outlined text-[20px] text-on-secondary-container">warning</span>
                <span class="font-bold text-sm tracking-wider uppercase">⚠️ Fraud Alert Detected</span>
            </div>
            <div class="relative z-10 mt-1">
                <p class="font-bold text-lg mb-1">$${parseFloat(data.amount).toLocaleString(undefined, {minimumFractionDigits: 2})}</p>
                <p class="text-xs text-white/90">Score: <strong class="text-white">${(data.score * 100).toFixed(1)}%</strong> | Flagged category: <strong>${data.category}</strong></p>
                <div class="mt-2 flex flex-col gap-1 text-[11px] text-white/80 border-t border-white/10 pt-2">
                    ${data.reasons.map(r => `<div>• ${r}</div>`).join('')}
                </div>
            </div>
        `;
        
        container.appendChild(toast);
        
        // Auto remove after 8 seconds
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100px)';
            setTimeout(() => toast.remove(), 300);
        }, 8000);
    }

    // Connect Server-Sent Events (SSE) listener
    if (typeof EventSource !== "undefined") {
        const eventSource = new EventSource("/stream");
        eventSource.onmessage = function(event) {
            try {
                const data = JSON.parse(event.data);
                if (data.type === 'fraud_alert') {
                    showFraudToast(data);
                }
            } catch (err) {
                console.error("Error parsing SSE data:", err);
            }
        };
    }
</script>
