<script>
    // Lightweight 3D Tilt Effect for cards
    function tilt(event, element) {
        if (!window.matchMedia("(pointer: fine)").matches) return;
        const rect = element.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateX = ((y - centerY) / centerY) * -5; // Max 5deg tilt
        const rotateY = ((x - centerX) / centerX) * 5;
        
        element.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
    }

    function resetTilt(element) {
        element.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
    }

    // Dynamic Orb movements
    document.addEventListener('mousemove', (e) => {
        const orbs = document.querySelectorAll('.ambient-orb');
        if (orbs.length >= 2) {
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            orbs[0].style.transform = `translate(${x * 20}px, ${y * 20}px)`;
            orbs[1].style.transform = `translate(${x * -30}px, ${y * -30}px)`;
        }
    });

    // Real-Time Fraud Alert Toast Renderer
    function showFraudToast(data) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = "pointer-events-auto bg-gradient-to-br from-secondary to-[#da3339] text-white p-5 rounded-2xl shadow-[0_8px_32px_rgba(182,21,36,0.3)] border border-white/20 slide-in transform transition-all duration-300 flex flex-col gap-2 relative overflow-hidden";
        
        toast.innerHTML = `
            <div class="absolute top-0 right-0 p-4 opacity-10">
                <span class="material-symbols-outlined text-6xl">warning</span>
            </div>
            <div class="flex items-center gap-2 relative z-10">
                <span class="material-symbols-outlined text-[20px] text-on-secondary-container">warning</span>
                <span class="font-bold text-sm tracking-wider uppercase">⚠️ Fraud Alert Detected</span>
            </div>
            <div class="relative z-10 mt-1">
                <p class="font-bold text-lg mb-1">$${parseFloat(data.amount).toLocaleString(undefined, {minimumFractionDigits: 2})}</p>
                <p class="text-xs text-white/90">Score: <strong class="text-white">${(data.score * 100).toFixed(1)}%</strong> | Flagged category: <strong>${data.category}</strong></p>
                <div class="mt-2 flex flex-col gap-1 text-[11px] text-white/80 border-t border-white/10 pt-2">
                    ${data.reasons.map(r => `<div>• ${r}</div>`).join('')}
                </div>
            </div>
        `;
        
        container.appendChild(toast);
        
        // Auto remove after 8 seconds
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100px)';
            setTimeout(() => toast.remove(), 300);
        }, 8000);
    }

    // Fetch and load AI Advisor Insights dynamically
    async function loadAIAdvisor() {
        const loadingEl = document.getElementById('ai-advisor-loading');
        const contentEl = document.getElementById('ai-advisor-content');
        if (!loadingEl || !contentEl) return;

        try {
            const res = await fetch('/advice/insights');
            const data = await res.json();
            
            if (data.success && data.advice && data.advice.length > 0) {
                loadingEl.classList.add('hidden');
                contentEl.innerHTML = '';
                
                data.advice.forEach(tip => {
                    const tipCard = document.createElement('div');
                    tipCard.className = 'flex gap-3 items-start p-4 rounded-lg bg-surface-container/50 border border-outline-variant/10 hover:border-primary/20 transition-all duration-300';
                    tipCard.innerHTML = `
                        <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                            <span class="material-symbols-outlined text-[18px]">wb_incandescent</span>
                        </div>
                        <div>
                            <p class="text-sm text-on-surface font-semibold">${tip}</p>
                        </div>
                    `;
                    contentEl.appendChild(tipCard);
                });
                contentEl.classList.remove('hidden');
            } else {
                throw new Error("Invalid response format");
            }
        } catch (err) {
            console.error("[Advisor] Failed loading AI tips:", err);
            loadingEl.innerHTML = `
                <span class="material-symbols-outlined text-error text-[20px]">error</span>
                <span class="text-sm text-error font-medium">Failed to compile AI insights. Please refresh the page to try again.</span>
            `;
        }
    }
    
    // Launch on page load & date filter dropdown toggle logic
    document.addEventListener('DOMContentLoaded', () => {
        const dropdownBtn = document.getElementById('dropdown-btn');
        const dropdownMenu = document.getElementById('dropdown-menu');

        if (dropdownBtn && dropdownMenu) {
            dropdownBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                dropdownMenu.classList.toggle('hidden');
            });

            document.addEventListener('click', (e) => {
                if (!dropdownBtn.contains(e.target) && !dropdownMenu.contains(e.target)) {
                    dropdownMenu.classList.add('hidden');
                }
            });
        }
        
        loadAIAdvisor();
    });

</script>
<script src="/js/sse.js"></script>
<script src="/js/web3-universe.js"></script>
