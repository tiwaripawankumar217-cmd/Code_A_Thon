<% layout('layouts/boilerplate') -%>

<!-- Ambient Background Orbs -->
<div class="bg-orb w-[600px] h-[600px] bg-[#FFF8E7] top-[-100px] left-[-100px]"></div>
<div class="bg-orb w-[500px] h-[500px] bg-[#FFEDEA] bottom-[-50px] right-[-50px]" style="animation-delay: -10s;"></div>
<!-- Main Container -->
<main class="relative z-10 w-full max-w-[480px] px-margin-mobile md:px-0">
    <!-- Glassmorphism Register Card -->
    <div class="glass-card tilt-card rounded-2xl p-container-padding shadow-ambient-amber flex flex-col items-center" id="registerCard">
        <!-- Brand Header -->
        <div class="flex flex-col items-center mb-6 w-full">
            <div class="w-16 h-16 rounded-full bg-primary-container/10 flex items-center justify-center mb-4 text-primary">
                <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">person_add</span>
            </div>
            <h1 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-primary text-center mb-2">Create Account</h1>
            <p class="font-body-sm text-body-sm text-on-surface-variant text-center">Join FraudGuard today</p>
        </div>
        <!-- Register Form -->
        <form class="w-full space-y-4" action="/auth/register" method="POST">
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="font-label-md text-label-md text-on-surface block" for="firstName">First Name</label>
                    <input class="w-full bg-cream border border-outline-variant rounded-lg py-3 px-4 font-body-lg text-body-lg text-on-surface focus:outline-none focus:border-coral focus:ring-1 focus:ring-coral transition-colors" id="firstName" name="firstName" required="" type="text"/>
                </div>
                <div class="space-y-2">
                    <label class="font-label-md text-label-md text-on-surface block" for="lastName">Last Name</label>
                    <input class="w-full bg-cream border border-outline-variant rounded-lg py-3 px-4 font-body-lg text-body-lg text-on-surface focus:outline-none focus:border-coral focus:ring-1 focus:ring-coral transition-colors" id="lastName" name="lastName" required="" type="text"/>
                </div>
            </div>
            <!-- Email Field -->
            <div class="space-y-2">
                <label class="font-label-md text-label-md text-on-surface block" for="username">Email</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant" style="font-variation-settings: 'FILL' 0;">mail</span>
                    <input class="w-full bg-cream border border-outline-variant rounded-lg py-3 pl-12 pr-4 font-body-lg text-body-lg text-on-surface focus:outline-none focus:border-coral focus:ring-1 focus:ring-coral transition-colors" id="username" name="username" placeholder="name@company.com" required="" type="email"/>
                </div>
            </div>
            <!-- Password Field -->
            <div class="space-y-2">
                <div class="flex justify-between items-center">
                    <label class="font-label-md text-label-md text-on-surface block" for="password">Password</label>
                </div>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant" style="font-variation-settings: 'FILL' 0;">lock</span>
                    <input class="w-full bg-cream border border-outline-variant rounded-lg py-3 pl-12 pr-4 font-body-lg text-body-lg text-on-surface focus:outline-none focus:border-coral focus:ring-1 focus:ring-coral transition-colors" id="password" name="password" placeholder="••••••••" required="" type="password"/>
                </div>
            </div>
            <!-- Submit Button -->
            <button class="w-full bg-gradient-to-b from-[#ff8554] to-[#FF6B35] text-white font-title-md text-title-md py-4 rounded-lg shadow-sm hover:shadow-md active:scale-[0.98] transition-all flex items-center justify-center gap-2 mt-4" type="submit">
                Create Account
                <span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 0;">person_add</span>
            </button>
        </form>
        <!-- Footer Link -->
        <div class="mt-6 pt-4 border-t border-outline-variant/30 w-full text-center">
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center gap-2" href="/auth/login">
                <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 0;">login</span>
                Already have an account? Sign In
            </a>
        </div>
    </div>
</main>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const card = document.getElementById('registerCard');
        if (window.matchMedia("(pointer: fine)").matches) {
            document.addEventListener('mousemove', (e) => {
                const xAxis = (window.innerWidth / 2 - e.pageX) / 50;
                const yAxis = (window.innerHeight / 2 - e.pageY) / 50;
                card.style.transform = `perspective(1000px) rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
            });
            document.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1000px) rotateY(0deg) rotateX(0deg)';
            });
        }
    });
</script>
