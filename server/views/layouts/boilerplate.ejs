<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>FraudGuard - Fintech Dashboard</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-dim": "#dcd9d9",
                        "on-secondary-container": "#fffbff",
                        "inverse-surface": "#303030",
                        "error": "#ba1a1a",
                        "primary-container": "#ff6b35",
                        "outline": "#8d7168",
                        "surface-variant": "#e4e2e1",
                        "on-background": "#1b1c1c",
                        "tertiary": "#7f5700",
                        "secondary": "#b61524",
                        "secondary-fixed": "#ffdad7",
                        "surface": "#fcf9f8",
                        "background": "#fcf9f8",
                        "surface-container": "#f0eded",
                        "on-error": "#ffffff",
                        "on-surface-variant": "#594139",
                        "on-secondary-fixed": "#410005",
                        "tertiary-container": "#cc8e00",
                        "on-primary-fixed-variant": "#832600",
                        "error-container": "#ffdad6",
                        "surface-container-lowest": "#ffffff",
                        "secondary-fixed-dim": "#ffb3ae",
                        "on-error-container": "#93000a",
                        "primary-fixed-dim": "#ffb59d",
                        "on-primary-fixed": "#390c00",
                        "surface-container-low": "#f6f3f2",
                        "on-tertiary": "#ffffff",
                        "outline-variant": "#e1bfb5",
                        "primary": "#ab3500",
                        "on-surface": "#1b1c1c",
                        "on-primary-container": "#5f1900",
                        "on-secondary-fixed-variant": "#930016",
                        "primary-fixed": "#ffdbd0",
                        "on-secondary": "#ffffff",
                        "inverse-primary": "#ffb59d",
                        "secondary-container": "#da3339",
                        "on-primary": "#ffffff",
                        "tertiary-fixed": "#ffdead",
                        "surface-container-highest": "#e4e2e1",
                        "on-tertiary-fixed-variant": "#604100",
                        "on-tertiary-fixed": "#281900",
                        "inverse-on-surface": "#f3f0f0",
                        "surface-container-high": "#eae7e7",
                        "surface-bright": "#fcf9f8",
                        "on-tertiary-container": "#452d00",
                        "tertiary-fixed-dim": "#ffba3b",
                        "surface-tint": "#ab3500",
                        "cream": "#FAF7F2",
                        "coral": "#FF4E50",
                        "amber-shadow": "rgba(184,134,11,0.08)"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "section-gap": "48px",
                        "container-padding": "32px",
                        "base": "8px",
                        "margin-mobile": "16px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "headline-lg": ["Manrope"],
                        "headline-lg-mobile": ["Manrope"],
                        "body-lg": ["Plus Jakarta Sans"],
                        "title-md": ["Manrope"],
                        "label-md": ["Manrope"],
                        "display-lg": ["Manrope"],
                        "body-sm": ["Plus Jakarta Sans"]
                    },
                    "fontSize": {
                        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "title-md": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                        "label-md": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700" }],
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }]
                    },
                    "boxShadow": {
                        "ambient-amber": "0 20px 40px rgba(184,134,11,0.08)",
                    }
                }
            }
        }
    </script>
    <link href="/css/style.css" rel="stylesheet"/>
</head>
<body class="bg-background min-h-screen flex items-center justify-center relative overflow-hidden font-body-lg text-on-surface">
    <!-- Flash Messages (if any) -->
    <%- include('../partials/flash') %>
    
    <%- body %>
</body>
</html>
