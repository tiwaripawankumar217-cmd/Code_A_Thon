<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>FraudGuard - Fintech Dashboard</title>
    
    <script>
        // Prevent flash of wrong theme (FOUC)
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
            document.documentElement.classList.remove('light');
        } else {
            document.documentElement.classList.add('light');
            document.documentElement.classList.remove('dark');
        }
    </script>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-dim": "#dcd9d9",
                        "on-secondary-container": "#fffbff",
                        "inverse-surface": "#303030",
                        "error": "#ba1a1a",
                        "primary-container": "#ff6b35",
                        "outline": "#8d7168",
                        "surface-variant": "#e4e2e1",
                        "on-background": "#1b1c1c",
                        "tertiary": "#7f5700",
                        "secondary": "#b61524",
                        "secondary-fixed": "#ffdad7",
                        "surface": "#fcf9f8",
                        "background": "#fcf9f8",
                        "surface-container": "#f0eded",
                        "on-error": "#ffffff",
                        "on-surface-variant": "#594139",
                        "on-secondary-fixed": "#410005",
                        "tertiary-container": "#cc8e00",
                        "on-primary-fixed-variant": "#832600",
                        "error-container": "#ffdad6",
                        "surface-container-lowest": "#ffffff",
                        "secondary-fixed-dim": "#ffb3ae",
                        "on-error-container": "#93000a",
                        "primary-fixed-dim": "#ffb59d",
                        "on-primary-fixed": "#390c00",
                        "surface-container-low": "#f6f3f2",
                        "on-tertiary": "#ffffff",
                        "outline-variant": "#e1bfb5",
                        "primary": "#ab3500",
                        "on-surface": "#1b1c1c",
                        "on-primary-container": "#5f1900",
                        "on-secondary-fixed-variant": "#930016",
                        "primary-fixed": "#ffdbd0",
                        "on-secondary": "#ffffff",
                        "inverse-primary": "#ffb59d",
                        "secondary-container": "#da3339",
                        "on-primary": "#ffffff",
                        "tertiary-fixed": "#ffdead",
                        "surface-container-highest": "#e4e2e1",
                        "on-tertiary-fixed-variant": "#604100",
                        "on-tertiary-fixed": "#281900",
                        "inverse-on-surface": "#f3f0f0",
                        "surface-container-high": "#eae7e7",
                        "surface-bright": "#fcf9f8",
                        "on-tertiary-container": "#452d00",
                        "tertiary-fixed-dim": "#ffba3b",
                        "surface-tint": "#ab3500",
                        "cream": "#FAF7F2",
                        "coral": "#FF4E50",
                        "amber-shadow": "rgba(184,134,11,0.08)"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "section-gap": "48px",
                        "container-padding": "32px",
                        "base": "8px",
                        "margin-mobile": "16px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "headline-lg": ["Manrope"],
                        "headline-lg-mobile": ["Manrope"],
                        "body-lg": ["Plus Jakarta Sans"],
                        "title-md": ["Manrope"],
                        "label-md": ["Manrope"],
                        "display-lg": ["Manrope"],
                        "body-sm": ["Plus Jakarta Sans"]
                    },
                    "fontSize": {
                        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "title-md": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                        "label-md": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700" }],
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }]
                    },
                    "boxShadow": {
                        "ambient-amber": "0 20px 40px rgba(184,134,11,0.08)",
                    }
                }
            }
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/ethers@5.7.2/dist/ethers.umd.min.js"></script>
    <script src="/js/page-transition.js?v=2"></script>
    <link href="/css/style.css?v=2" rel="stylesheet"/>
</head>
<body class="bg-background min-h-screen flex items-center justify-center relative overflow-hidden font-body-lg text-on-surface transition-colors duration-300">
    <!-- Flash Messages (if any) -->
    <%- include('../partials/flash') %>
    
    <!-- Global Desktop Top-Right Profile Widget -->
    <% if (typeof currentUser !== 'undefined' && currentUser && typeof activePage !== 'undefined' && activePage !== '/auth/login' && activePage !== '/auth/register') { %>
    <% 
        let headerDisplayName = "Guest";
        if (currentUser.firstName || currentUser.lastName) {
            headerDisplayName = (currentUser.firstName + ' ' + currentUser.lastName).trim();
        } else {
            headerDisplayName = currentUser.username;
        }
    %>
    <div class="hidden md:flex fixed top-10 right-8 z-40 items-center gap-3 bg-[#fcf9f8]/90 dark:bg-[#121314]/90 backdrop-blur-xl border border-outline-variant/30 dark:border-white/10 px-4 py-2 rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.08)] transition-all select-none hover:scale-[1.02] duration-300">
        <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-[#ff8555] to-[#ff6b35] flex items-center justify-center text-white font-bold text-xs shadow-sm font-headline-lg shrink-0">
            <%= headerDisplayName.charAt(0).toUpperCase() %>
        </div>
        <div class="flex flex-col">
            <span class="font-bold text-xs text-on-surface leading-tight"><%= headerDisplayName %></span>
            <div class="flex items-center gap-1 mt-0.5">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-[9px] font-bold text-on-surface-variant/80 uppercase tracking-wider leading-none">Authorized</span>
            </div>
        </div>
    </div>
    <% } %>

    <%- body %>

    <script>
        function toggleTheme() {
            const html = document.documentElement;
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                html.classList.add('light');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.remove('light');
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
            updateThemeToggleUI();
        }

        function updateThemeToggleUI() {
            const isDark = document.documentElement.classList.contains('dark');
            // Update all toggle pill UIs on the page
            document.querySelectorAll('.theme-toggle-pill').forEach(pill => {
                const knob = pill.querySelector('.theme-knob');
                const sunIcon = pill.querySelector('.sun-icon');
                const moonIcon = pill.querySelector('.moon-icon');
                if (isDark) {
                    knob.style.transform = 'translateX(24px)';
                    pill.style.background = 'rgba(255, 107, 53, 0.25)';
                    if (sunIcon) sunIcon.style.opacity = '0.4';
                    if (moonIcon) moonIcon.style.opacity = '1';
                } else {
                    knob.style.transform = 'translateX(0px)';
                    pill.style.background = 'rgba(141, 113, 104, 0.15)';
                    if (sunIcon) sunIcon.style.opacity = '1';
                    if (moonIcon) moonIcon.style.opacity = '0.4';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateThemeToggleUI();
        });
    </script>

    <!-- ============================================================
         MODERN GLASSMORPHIC AI ASSISTANT CHATBOT UI
         ============================================================ -->
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <!-- NEW MODULAR MORPHING CHATBOT WIDGET -->
    <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end font-body-lg">
        
        <!-- Chatbot Box (Supports 'little' state and 'full' state) -->
        <div id="newAiChatbox" class="hidden flex-col w-[365px] bg-[#fcf9f8] dark:bg-[#121314] border border-outline-variant/30 dark:border-white/10 rounded-2xl shadow-[0_15px_40px_rgba(255,107,53,0.15)] overflow-hidden transition-all duration-300 origin-bottom-right mb-4">
            
            <!-- Compact Header (Always visible when open) -->
            <div class="bg-gradient-to-r from-[#ff8555] to-[#ff6b35] px-4 py-3 flex items-center justify-between text-white select-none">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px] font-bold">psychology</span>
                    <span class="font-bold text-xs uppercase tracking-wider">FraudGuard AI</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <!-- Clear/Reset conversation button -->
                    <button onclick="clearChatHistory()" class="text-white/80 hover:text-white transition-colors p-1 hover:bg-white/10 rounded" title="Clear Conversation">
                        <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                    </button>
                    <!-- Expand/Collapse toggle button -->
                    <button onclick="toggleExpandChat()" id="chatExpandBtn" class="text-white/80 hover:text-white transition-colors p-1 hover:bg-white/10 rounded" title="Expand View">
                        <span class="material-symbols-outlined text-[18px]" id="expandIcon">open_in_full</span>
                    </button>
                    <button onclick="closeNewChat()" class="text-white/80 hover:text-white transition-colors p-1 hover:bg-white/10 rounded" title="Close Chat">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </button>
                </div>
            </div>

            <!-- Messages Container (Starts hidden in 'little' state, expands in 'full') -->
            <div id="newChatMessagesContainer" class="hidden flex-col h-[330px] overflow-y-auto p-4 space-y-3 scroll-smooth border-b border-outline-variant/20 dark:border-white/5 bg-[#faf7f2] dark:bg-[#161718]">
                <!-- Initial Welcome message -->
                <div class="flex gap-2 items-start">
                    <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-[#ff8555] to-[#ff6b35] flex items-center justify-center text-white shrink-0">
                        <span class="material-symbols-outlined text-[13px]">psychology</span>
                    </div>
                    <div class="bg-[#f0eded] dark:bg-white/5 border border-outline-variant/10 dark:border-white/5 px-3 py-2 rounded-xl text-xs max-w-[80%] text-on-surface">
                        Hi! I am ready. What would you like to ask about the website or your statistics?
                    </div>
                </div>
            </div>

            <!-- Mini Greeting & Action Panel ('Open at Little' state highlights) -->
            <div id="newChatGreetingPanel" class="p-4 bg-[#faf7f2] dark:bg-[#161718] border-b border-outline-variant/10 dark:border-white/5 space-y-3">
                <p class="text-[11px] font-semibold text-on-surface-variant leading-relaxed">
                    👋 Ask me about your **Expenses**, **Savings Goals**, **Budgets**, or security alerts on this website!
                </p>
                <div class="flex flex-wrap gap-1.5">
                    <button onclick="triggerPrompt('Budget Analysis')" class="text-[10px] font-bold text-[#ff6b35] bg-[#ff6b35]/10 border border-[#ff6b35]/15 px-2.5 py-1 rounded-full hover:bg-[#ff6b35]/20 active:scale-95 transition-all">Budget Analysis</button>
                    <button onclick="triggerPrompt('Savings Tips')" class="text-[10px] font-bold text-emerald-500 bg-emerald-500/10 border border-emerald-500/15 px-2.5 py-1 rounded-full hover:bg-emerald-500/20 active:scale-95 transition-all">Savings Tips</button>
                </div>
            </div>

            <!-- Typing Indicator (Hidden by default) -->
            <div id="newChatTyping" class="hidden px-4 py-2 bg-[#faf7f2] dark:bg-[#161718]">
                <div class="typing-dots flex gap-1 items-center bg-[#faf7f2] dark:bg-white/5 border border-outline-variant/10 dark:border-white/5 px-3 py-2 rounded-full w-max shadow-sm">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>

            <!-- Input Bar -->
            <div class="p-3 bg-[#fcf9f8] dark:bg-[#121314] flex gap-2 items-center">
                <input id="newChatInput" type="text" placeholder="Type a message..." class="chat-input-text flex-grow rounded-xl bg-[#faf7f2] dark:bg-white/5 border border-outline-variant/30 dark:border-white/10 text-on-surface dark:text-white placeholder-slate-500 dark:placeholder-slate-400 px-3.5 py-2 text-xs focus:outline-none focus:border-[#ff6b35] focus:ring-1 focus:ring-[#ff6b35] transition-all" onkeydown="if(event.key === 'Enter') submitNewChatMessage();" onclick="expandToFullChat()"/>
                <button onclick="submitNewChatMessage()" class="w-8 h-8 rounded-lg bg-gradient-to-tr from-[#ff8555] to-[#ff6b35] text-white flex items-center justify-center shadow hover:scale-105 active:scale-95 transition-all shrink-0">
                    <span class="material-symbols-outlined text-[16px] font-bold">send</span>
                </button>
            </div>
        </div>

        <!-- Floating Assistant Trigger Button -->
        <button onclick="toggleNewAIChat()" class="chatbot-float-btn w-14 h-14 md:w-16 md:h-16 rounded-full bg-gradient-to-tr from-[#ff8555] via-[#ff7844] to-[#ff6b35] shadow-[0_8px_32px_rgba(255,107,53,0.35)] flex items-center justify-center text-white cursor-pointer select-none transition-all duration-300 hover:scale-110 active:scale-95">
            <span class="material-symbols-outlined text-3xl font-bold">psychology</span>
        </button>
    </div>

    <script>
        let chatState = 'closed'; // 'closed' | 'little' | 'full'
        let newHistory = [];

        function toggleNewAIChat() {
            if (chatState === 'closed') {
                openLittleChat();
            } else {
                closeNewChat();
            }
        }

        function openLittleChat() {
            const chatbox = document.getElementById('newAiChatbox');
            chatbox.classList.remove('hidden');
            
            // Set 'little' (compact) size
            chatbox.style.width = '365px';
            document.getElementById('newChatMessagesContainer').classList.add('hidden');
            document.getElementById('newChatGreetingPanel').classList.remove('hidden');
            document.getElementById('expandIcon').textContent = 'open_in_full';
            
            chatState = 'little';
        }

        function expandToFullChat() {
            if (chatState !== 'little') return;
            
            const chatbox = document.getElementById('newAiChatbox');
            chatbox.style.width = '375px';
            document.getElementById('newChatGreetingPanel').classList.add('hidden');
            document.getElementById('newChatMessagesContainer').classList.remove('hidden');
            document.getElementById('newChatMessagesContainer').style.display = 'flex';
            document.getElementById('expandIcon').textContent = 'close_fullscreen';
            
            chatState = 'full';
            setTimeout(scrollToNewBottom, 10);
        }

        function toggleExpandChat() {
            if (chatState === 'little') {
                expandToFullChat();
            } else if (chatState === 'full') {
                openLittleChat();
            }
        }

        function closeNewChat() {
            const chatbox = document.getElementById('newAiChatbox');
            chatbox.classList.add('hidden');
            chatState = 'closed';
        }

        function clearChatHistory() {
            newHistory = [];
            const container = document.getElementById('newChatMessagesContainer');
            container.innerHTML = `
                <!-- Initial Welcome message -->
                <div class="flex gap-2 items-start animate-fade-in">
                    <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-[#ff8555] to-[#ff6b35] flex items-center justify-center text-white shrink-0">
                        <span class="material-symbols-outlined text-[13px]">psychology</span>
                    </div>
                    <div class="bg-[#f0eded] dark:bg-white/5 border border-outline-variant/10 dark:border-white/5 px-3 py-2 rounded-xl text-xs max-w-[80%] text-on-surface">
                        Hi! I am ready. What would you like to ask about the website or your statistics?
                    </div>
                </div>
            `;
            openLittleChat();
        }

        function triggerPrompt(promptText) {
            expandToFullChat();
            submitNewChatMessage(promptText);
        }

        async function submitNewChatMessage(customText = null) {
            const inputEl = document.getElementById('newChatInput');
            const text = customText ? customText : inputEl.value.trim();
            if (!text) return;

            if (!customText) inputEl.value = '';

            // Ensure we are fully expanded to show conversation
            expandToFullChat();

            // Render User bubble
            renderNewMessage(text, 'user');

            // Show Typing Indicator
            const typing = document.getElementById('newChatTyping');
            typing.classList.remove('hidden');
            scrollToNewBottom();

            try {
                const response = await fetch('/chat/message', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text, chatHistory: newHistory })
                });

                const data = await response.json();
                typing.classList.add('hidden');

                if (data.success && data.reply) {
                    renderNewMessage(data.reply, 'ai');
                    newHistory.push({ role: 'user', text: text });
                    newHistory.push({ role: 'model', text: data.reply });
                    if (newHistory.length > 20) newHistory.shift();
                } else {
                    renderNewMessage('Sorry, I experienced a minor technical issue. Please try asking again.', 'ai');
                }
            } catch (err) {
                typing.classList.add('hidden');
                renderNewMessage('Unable to connect to the assistant right now. Please check your network connection.', 'ai');
            }
            scrollToNewBottom();
        }

        function renderNewMessage(text, sender) {
            const container = document.getElementById('newChatMessagesContainer');
            const wrapper = document.createElement('div');
            wrapper.className = `flex gap-2 items-start ${sender === 'user' ? 'justify-end' : ''}`;

            const time = new Date().toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });

            if (sender === 'user') {
                wrapper.innerHTML = `
                    <div class="flex flex-col items-end max-w-[80%]">
                        <div class="bg-gradient-to-tr from-[#ff8555] to-[#ff6b35] text-white px-3.5 py-2 rounded-2xl text-xs leading-relaxed shadow-sm">
                            <p>${escapeNewHtml(text)}</p>
                        </div>
                        <span class="text-[9px] text-slate-500 dark:text-slate-400 mt-1 mr-1">${time}</span>
                    </div>
                `;
            } else {
                const formatted = formatNewMarkdown(text);
                wrapper.innerHTML = `
                    <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-[#ff8555] to-[#ff6b35] flex items-center justify-center text-white shrink-0 shadow-sm mt-0.5">
                        <span class="material-symbols-outlined text-[13px]">psychology</span>
                    </div>
                    <div class="flex flex-col max-w-[80%]">
                        <div class="bg-[#f0eded] dark:bg-white/5 border border-outline-variant/10 dark:border-white/5 text-on-surface dark:text-[#f1f5f9] px-3.5 py-2 rounded-2xl text-xs leading-relaxed">
                            <p>${formatted}</p>
                        </div>
                        <span class="text-[9px] text-slate-500 dark:text-slate-400 mt-1 ml-1">${time}</span>
                    </div>
                `;
            }

            container.appendChild(wrapper);
            scrollToNewBottom();
        }

        function scrollToNewBottom() {
            const container = document.getElementById('newChatMessagesContainer');
            container.scrollTop = container.scrollHeight;
        }

        function escapeNewHtml(str) {
            return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        }

        function formatNewMarkdown(text) {
            return text
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.*?)\*/g, '<em>$1</em>')
                .replace(/\n\* (.*?)/g, '<br/>• $1')
                .replace(/\n- (.*?)/g, '<br/>• $1')
                .replace(/\n/g, '<br/>');
        }
    </script>
    <% } %>
</body>
</html>
