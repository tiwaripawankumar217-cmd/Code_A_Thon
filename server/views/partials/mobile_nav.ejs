<!-- Mobile Bottom NavBar (Visible only on md:hidden) -->
<div class="md:hidden fixed bottom-0 w-full bg-surface-container-low border-t border-outline-variant/20 flex justify-around items-center py-3 z-50 px-4 pb-safe shadow-[0_-4px_20px_rgba(0,0,0,0.05)]">
    <a class="flex flex-col items-center gap-1 <%= (activePage === '/dashboard' || activePage === '/') ? 'text-primary' : 'text-on-surface-variant hover:text-on-surface' %>" href="/dashboard">
        <div class="<%= (activePage === '/dashboard' || activePage === '/') ? 'bg-primary-container/20' : '' %> px-4 py-1 rounded-full">
            <span class="material-symbols-outlined" style="<%= (activePage === '/dashboard' || activePage === '/') ? 'font-variation-settings: \'FILL\' 1;' : '' %>">dashboard</span>
        </div>
        <span class="text-[10px] <%= (activePage === '/dashboard' || activePage === '/') ? 'font-bold' : 'font-medium' %>">Dashboard</span>
    </a>
    <a class="flex flex-col items-center gap-1 <%= activePage.startsWith('/transactions') ? 'text-primary' : 'text-on-surface-variant hover:text-on-surface' %>" href="/transactions">
        <div class="<%= activePage.startsWith('/transactions') ? 'bg-primary-container/20' : '' %> px-4 py-1 rounded-full">
            <span class="material-symbols-outlined" style="<%= activePage.startsWith('/transactions') ? 'font-variation-settings: \'FILL\' 1;' : '' %>">receipt_long</span>
        </div>
        <span class="text-[10px] <%= activePage.startsWith('/transactions') ? 'font-bold' : 'font-medium' %>">Txns</span>
    </a>
    <a class="flex flex-col items-center gap-1 <%= activePage.startsWith('/budgets') ? 'text-primary' : 'text-on-surface-variant hover:text-on-surface' %>" href="/budgets">
        <div class="<%= activePage.startsWith('/budgets') ? 'bg-primary-container/20' : '' %> px-4 py-1 rounded-full">
            <span class="material-symbols-outlined" style="<%= activePage.startsWith('/budgets') ? 'font-variation-settings: \'FILL\' 1;' : '' %>">analytics</span>
        </div>
        <span class="text-[10px] <%= activePage.startsWith('/budgets') ? 'font-bold' : 'font-medium' %>">Budgets</span>
    </a>
</div>
