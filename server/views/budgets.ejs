<% layout('layouts/boilerplate') -%>

<!-- SideNavBar and Mobile TopBar (Partials) -->
<%- include('partials/sidebar') %>

<div class="flex h-screen overflow-hidden w-full">
    <!-- Main Content -->
    <main class="flex-grow ml-0 md:ml-64 pt-24 md:pt-8 pb-24 px-margin-mobile md:px-container-padding max-w-[1440px] mx-auto overflow-y-auto relative">
        
        <!-- Header -->
        <header class="flex flex-col md:flex-row md:justify-between md:items-end mb-6 gap-4">
            <div>
                <p class="font-label-md text-label-md text-primary tracking-wider uppercase mb-1">Financial Operations</p>
                <h2 class="font-display-lg text-display-lg text-on-background">Budget Oversight</h2>
            </div>
            <div class="flex flex-wrap gap-3">
                <!-- Reset Budgets Form -->
                <form action="/budgets/reset" method="POST" onsubmit="return confirm('Reset all budgets for this month? This cannot be undone.')">
                    <button type="submit" class="border border-outline-variant text-on-surface-variant px-5 py-3 rounded-xl font-label-md text-label-md hover:bg-surface-container hover:border-secondary hover:text-secondary transition-all flex items-center gap-2 active:scale-95">
                        <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                        Reset Month
                    </button>
                </form>
                <button onclick="openModal()" class="bg-gradient-to-b from-[#FF8B5A] to-[#FF6B35] text-white px-6 py-3 rounded-xl font-label-md text-label-md shadow-[0_4px_14px_rgba(255,107,53,0.3)] hover:shadow-[0_6px_20px_rgba(255,107,53,0.4)] transition-all flex items-center gap-2 active:scale-95 group">
                    <span class="material-symbols-outlined group-hover:rotate-90 transition-transform">add</span>
                    New Budget
                </button>
            </div>
        </header>

        <!-- Error Banner -->
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-6 p-4 rounded-xl bg-error-container/30 border border-error/30 flex items-start gap-3">
            <span class="material-symbols-outlined text-error mt-0.5" style="font-variation-settings: 'FILL' 1;">error</span>
            <div>
                <% if (error === 'exceeds_income') { %>
                    <p class="font-semibold text-error">Budget Exceeds Monthly Income</p>
                    <p class="text-sm text-on-surface-variant mt-0.5">
                        Total budget of $<%= typeof errorAttempted !== 'undefined' && errorAttempted ? errorAttempted.toLocaleString() : '—' %>
                        exceeds your monthly income of $<%= typeof errorIncome !== 'undefined' && errorIncome ? errorIncome.toLocaleString() : '—' %>.
                        Please reduce the limit amount.
                    </p>
                <% } else if (error === 'zero_income') { %>
                    <p class="font-semibold text-error">Zero Income</p>
                    <p class="text-sm text-on-surface-variant mt-0.5">
                        You cannot set a budget because your monthly income is $0. Please add an income transaction first.
                    </p>
                <% } %>
            </div>
            <button onclick="this.parentElement.remove()" class="ml-auto text-on-surface-variant hover:text-on-surface">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
        <% } %>

        <!-- Auto-Savings Surplus Panel -->
        <% 
            const mInc = (typeof monthlyIncome !== 'undefined') ? monthlyIncome : 0;
            const mLim = (typeof limitTotal !== 'undefined') ? limitTotal : 0;
            const surplus = Math.max(0, mInc - mLim);
        %>
        <% if (mInc > 0) { %>
        <div class="mb-6 rounded-xl px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3" style="background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(139,92,246,0.08)); border: 1px solid rgba(99,102,241,0.3);">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-indigo-400 mt-0.5" style="font-size:20px;">auto_fix_high</span>
                <div>
                    <span class="font-semibold text-indigo-300 text-sm">Auto-Savings Active</span>
                    <p class="text-xs text-on-surface-variant mt-0.5">
                        Every time you update your budget, the leftover income is automatically deposited into your savings goals (smallest goal first). Increasing your budget withdraws from savings.
                    </p>
                </div>
            </div>
            <div class="shrink-0 text-right">
                <div class="text-xs text-on-surface-variant uppercase tracking-wider mb-0.5">Current Surplus</div>
                <div class="text-2xl font-bold text-indigo-300">$<%= surplus.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="text-xs text-on-surface-variant">going to savings</div>
            </div>
        </div>
        <% } %>

        <!-- Top Overview Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter mb-section-gap w-full">
            <!-- Hero Card: Total Allocated Spend + Income Info -->
            <div class="glass-card rounded-2xl p-container-padding lg:col-span-2 relative overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent pointer-events-none rounded-2xl"></div>
                <!-- Income vs Budget summary -->
                <% const mIncome = (typeof monthlyIncome !== 'undefined') ? monthlyIncome : 0; %>
                <% if (mIncome > 0) { %>
                <div class="flex items-center gap-2 mb-4 px-3 py-2 rounded-lg bg-green-500/10 border border-green-500/20 w-fit">
                    <span class="material-symbols-outlined text-green-500 text-[16px]">account_balance</span>
                    <span class="text-xs font-medium text-green-500">Monthly Income: $<%= mIncome.toLocaleString(undefined, {minimumFractionDigits: 0}) %></span>
                    <% const remainingBudget = mIncome - (typeof limitTotal !== 'undefined' ? limitTotal : 0); %>
                    <span class="text-xs text-on-surface-variant ml-2">&mdash; $<%= Math.max(0, remainingBudget).toLocaleString(undefined, {minimumFractionDigits: 0}) %> unallocated</span>
                </div>
                <% } %>
                <div class="flex justify-between items-start mb-8 relative z-10">
                    <div>
                        <h3 class="font-title-md text-title-md text-on-surface-variant mb-2">Total Monthly Spend Limit</h3>
                        <div class="flex items-baseline gap-3">
                            <span class="font-display-lg text-display-lg text-on-background">
                                $<%= (typeof spentTotal !== 'undefined') ? spentTotal.toLocaleString(undefined, {minimumFractionDigits: 0}) : '0' %>
                            </span>
                            <span class="font-body-lg text-body-lg text-on-surface-variant">
                                / $<%= (typeof limitTotal !== 'undefined') ? limitTotal.toLocaleString(undefined, {minimumFractionDigits: 0}) : '0' %> Limit
                            </span>
                        </div>
                    </div>
                    <% 
                        let overallPercent = 0; 
                        if (typeof spentTotal !== 'undefined' && typeof limitTotal !== 'undefined' && limitTotal > 0) {
                            overallPercent = Math.round((spentTotal / limitTotal) * 100);
                        }
                    %>
                    <div class="bg-surface-container px-4 py-2 rounded-full border border-outline-variant/30 flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-primary-container pulse-ring"></div>
                        <span class="font-label-md text-label-md text-on-surface"><%= overallPercent %>% Utilized</span>
                    </div>
                </div>

                <!-- Horizontal Multi-segment Progress -->
                <div class="relative z-10">
                    <%
                        let segments = [];
                        if (typeof limitTotal !== 'undefined' && limitTotal > 0 && typeof categorySpent !== 'undefined') {
                            const colors = ['bg-primary', 'bg-tertiary', 'bg-outline', 'bg-secondary', 'bg-error'];
                            let colorIdx = 0;
                            for (const [cat, spent] of Object.entries(categorySpent)) {
                                if (spent > 0) {
                                    const width = (spent / limitTotal) * 100;
                                    segments.push({
                                        category: cat,
                                        width: width,
                                        colorClass: colors[colorIdx % colors.length]
                                    });
                                    colorIdx++;
                                }
                            }
                        }
                    %>
                    <div class="flex justify-between font-label-md text-label-md text-on-surface-variant mb-3 px-1">
                        <% if (segments.length > 0) { %>
                            <% segments.forEach(function(seg) { %>
                                <span><%= seg.category %></span>
                            <% }) %>
                        <% } else { %>
                            <span>No active spend segments</span>
                        <% } %>
                    </div>
                    <div class="h-4 w-full bg-surface-container-high rounded-full overflow-hidden flex shadow-inner">
                        <% if (segments.length > 0) { %>
                            <% segments.forEach(function(seg, idx) { %>
                                <div class="<%= seg.colorClass %> h-full <%= idx > 0 ? 'border-l border-white/20' : '' %>" style="width: <%= seg.width %>%" title="<%= seg.category %>: <%= Math.round(seg.width) %>%"></div>
                            <% }) %>
                        <% } else { %>
                            <div class="bg-outline-variant/20 h-full w-full" title="No budget utilization"></div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Warning Card: Compliance Alert -->
            <div class="glass-card rounded-2xl p-container-padding border-secondary-fixed/50 bg-secondary-fixed/10 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10">
                    <span class="material-symbols-outlined text-8xl text-secondary">warning</span>
                </div>
                <div class="relative z-10 flex flex-col h-full justify-between">
                    <div>
                        <div class="w-12 h-12 rounded-xl bg-error-container text-on-error-container flex items-center justify-center mb-6 shadow-sm">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">warning</span>
                        </div>
                        <h3 class="font-title-md text-title-md text-secondary mb-2">Compliance Alert</h3>
                        <p class="font-body-sm text-body-sm text-on-surface-variant mb-4">
                            Ensure category thresholds stay under alert levels. Active warning monitors trigger when budgets reach 80% usage.
                        </p>
                    </div>
                    <a href="/transactions" class="w-full py-3 bg-secondary text-on-secondary rounded-lg font-label-md text-label-md hover:bg-secondary/90 transition-colors shadow-sm flex items-center justify-center gap-2">
                        Review Ledger
                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Departmental Categories Header -->
        <div class="mb-8">
            <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-on-background mb-2">Category Breakdown</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant">See how your expenses are distributed across your global budget.</p>
        </div>

        <!-- Rings Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-gutter pb-20">
            <% 
                // We now iterate over actual expenses (categorySpent) and compare against the Global limit
                let activeRings = [];
                if (typeof categorySpent !== 'undefined') {
                    for (const [cat, spent] of Object.entries(categorySpent)) {
                        if (spent > 0) {
                            // Calculate percentage against the GLOBAL limit (or 0 if no limit)
                            const percent = (typeof limitTotal !== 'undefined' && limitTotal > 0) ? Math.round((spent / limitTotal) * 100) : 0;
                            
                            let colorClass = 'text-primary';
                            if (percent >= 100) colorClass = 'text-secondary font-bold';
                            else if (percent >= 80) colorClass = 'text-tertiary';
                            else if (percent >= 50) colorClass = 'text-outline';

                            activeRings.push({
                                category: cat,
                                spent: spent,
                                percent: percent,
                                colorClass: colorClass
                            });
                        }
                    }
                }
            %>

            <% if (activeRings.length === 0) { %>
                <div class="col-span-1 md:col-span-2 xl:col-span-4 p-8 text-center bg-surface-container/30 rounded-2xl border border-outline-variant/30">
                    <p class="text-on-surface-variant">No expenses recorded yet this month.</p>
                </div>
            <% } else { %>
                <% activeRings.forEach(function(b) { %>
                    <!-- Ring Card -->
                    <div class="glass-card rounded-2xl p-6 flex flex-col items-center text-center hover:translate-y-[-4px] transition-transform duration-300 relative group">
                        <h4 class="font-title-md text-title-md mb-6 <%= b.percent >= 100 ? 'text-secondary' : 'text-on-background' %>">
                            <%= b.category %>
                        </h4>
                        
                        <!-- Circular SVG Ring Progress -->
                        <div class="relative w-32 h-32 mb-6">
                            <%
                                const radius = 40;
                                const circumference = 251.2; // 2 * pi * r
                                const offset = circumference - (Math.min(b.percent, 100) / 100) * circumference;
                            %>
                            <svg class="w-full h-full" viewBox="0 0 100 100">
                                <!-- Background ring -->
                                <circle class="text-surface-container-high stroke-current" cx="50" cy="50" fill="transparent" r="40" stroke-width="8"></circle>
                                <!-- Foreground indicator ring -->
                                <circle class="<%= b.colorClass %> stroke-current progress-ring__circle" cx="50" cy="50" fill="transparent" r="40" 
                                        stroke-dasharray="<%= circumference %>" 
                                        stroke-dashoffset="<%= offset %>" 
                                        stroke-linecap="round" stroke-width="8"></circle>
                            </svg>
                            <div class="absolute inset-0 flex items-center justify-center flex-col">
                                <span class="font-headline-lg-mobile text-headline-lg-mobile <%= b.percent >= 100 ? 'text-secondary' : 'text-on-background' %>">
                                    <%= b.percent %>%
                                </span>
                            </div>
                        </div>

                        <div class="w-full pt-4 border-t border-outline-variant/20">
                            <div class="flex justify-between font-body-sm text-body-sm mb-1">
                                <span class="<%= b.percent >= 100 ? 'text-secondary font-medium' : 'text-on-surface-variant' %>">Spent</span>
                                <span class="font-medium <%= b.percent >= 100 ? 'text-secondary font-bold' : 'text-on-surface' %>">
                                    $<%= b.spent.toLocaleString() %>
                                </span>
                            </div>
                            <div class="flex justify-between font-body-sm text-body-sm">
                                <span class="text-on-surface-variant">Global Budget</span>
                                <span class="font-medium text-on-surface"><%= typeof limitTotal !== 'undefined' ? '$' + limitTotal.toLocaleString() : 'N/A' %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <!-- NEW BUDGET MODAL WINDOW -->
        <div id="budgetModal" class="fixed inset-0 z-50 bg-[#0d0d0d]/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
            <div class="glass-card rounded-2xl p-container-padding max-w-[420px] w-full flex flex-col relative mx-4 transform scale-95 transition-transform duration-300" id="modalCard">
                <button onclick="closeModal()" class="absolute top-4 right-4 text-on-surface-variant hover:text-on-surface transition-colors p-2 hover:bg-surface-container-high rounded-full">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>

                <h3 class="font-title-md text-title-md text-on-background mb-2 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">add_circle</span>
                    Set Spend Limit
                </h3>
                <% if (typeof monthlyIncome !== 'undefined' && monthlyIncome > 0) { %>
                <div class="mb-4 p-3 rounded-lg bg-green-500/10 border border-green-500/20 flex items-center gap-2">
                    <span class="material-symbols-outlined text-green-500 text-[16px]">account_balance</span>
                    <div class="text-xs">
                        <span class="text-green-500 font-medium">Monthly Income: $<%= monthlyIncome.toLocaleString(undefined, {minimumFractionDigits: 0}) %></span>
                        <span class="text-on-surface-variant ml-2">&mdash; Max total budget allowed: $<%= monthlyIncome.toLocaleString(undefined, {minimumFractionDigits: 0}) %></span>
                    </div>
                </div>
                <% } %>

                <form action="/budgets" method="POST" class="flex flex-col gap-4">
                    <!-- Category Select (Removed per request, Hardcoded to Global on Backend) -->

                    <!-- Limit Amount -->
                    <div>
                        <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="modalLimit">Limit Amount (USD)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant material-symbols-outlined" style="font-size: 18px;">attach_money</span>
                            <input class="w-full input-premium rounded-lg pl-10 pr-4 py-3 font-body-lg text-body-lg text-on-surface focus:ring-0" id="modalLimit" name="limitAmount" placeholder="500" min="1" required type="number"/>
                        </div>
                    </div>

                    <!-- Alert Threshold -->
                    <div>
                        <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="modalThreshold">Alert Threshold (%)</label>
                        <input class="w-full input-premium rounded-lg px-4 py-3 font-body-lg text-body-lg text-on-surface focus:ring-0" id="modalThreshold" name="alertThreshold" value="80" min="10" max="100" type="number"/>
                        <p class="text-[10px] text-on-surface-variant mt-1">We'll alert you once category spending reaches this percentage.</p>
                    </div>

                    <!-- Submit Button -->
                    <button class="btn-primary text-white font-title-md text-body-lg rounded-lg py-4 mt-4 flex items-center justify-center gap-2 transition-all w-full" type="submit">
                        <span class="material-symbols-outlined text-sm">save</span>
                        Save Budget Limit
                    </button>
                </form>
            </div>
        </div>
    </main>
</div>

<!-- Mobile Bottom NavBar (Partial) -->
<%- include('partials/mobile_nav') %>

<script>
    // Modal controls
    function openModal() {
        const modal = document.getElementById('budgetModal');
        const card = document.getElementById('modalCard');
        modal.classList.remove('pointer-events-none');
        modal.classList.remove('opacity-0');
        card.classList.remove('scale-95');
        card.classList.add('scale-100');
    }

    function closeModal() {
        const modal = document.getElementById('budgetModal');
        const card = document.getElementById('modalCard');
        modal.classList.add('pointer-events-none');
        modal.classList.add('opacity-0');
        card.classList.remove('scale-100');
        card.classList.add('scale-95');
    }

    // Close modal when clicking background
    document.getElementById('budgetModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });

    // Interactive Orb movements
    document.addEventListener('mousemove', (e) => {
        const orbs = document.querySelectorAll('.ambient-orb');
        if (orbs.length >= 2) {
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            orbs[0].style.transform = `translate(${x * 20}px, ${y * 20}px)`;
            orbs[1].style.transform = `translate(${x * -30}px, ${y * -30}px)`;
        }
    });
</script>
