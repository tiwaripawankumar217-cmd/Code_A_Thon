<% layout('layouts/boilerplate') -%>

<script>
    // Immediately block scrolling and hide the main card
    document.body.classList.add('preloader-active');
</script>

<!-- Minimalist Glowing Circular Preloader Overlay -->
<div class="preloader-overlay" id="preloader">
    <div class="preloader-circle-container">
        <!-- SVG Progress Ring -->
        <svg class="preloader-svg" viewBox="0 0 280 280">
            <circle class="preloader-track-circle" cx="140" cy="140" r="130"></circle>
            <circle class="preloader-progress-circle" id="progressCircle" cx="140" cy="140" r="130"></circle>
        </svg>
    </div>
</div>

<!-- Ambient Background Orbs -->
<div class="bg-orb w-[600px] h-[600px] bg-[#FFF8E7] top-[-100px] left-[-100px]"></div>
<div class="bg-orb w-[500px] h-[500px] bg-[#FFEDEA] bottom-[-50px] right-[-50px]" style="animation-delay: -10s;"></div>

<!-- Main Container -->
<main class="relative z-10 w-full max-w-[480px] px-margin-mobile md:px-0">
    <!-- Glassmorphism Login Card -->
    <div class="glass-card tilt-card rounded-2xl p-container-padding shadow-ambient-amber flex flex-col items-center" id="loginCard" style="opacity: 0; transform: scale(0.9) translateY(40px);">
        <!-- Brand Header -->
        <div class="flex flex-col items-center mb-8 w-full">
            <div class="w-16 h-16 rounded-full bg-primary-container/10 flex items-center justify-center mb-4 text-primary">
                <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">security</span>
            </div>
            <h1 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-primary text-center mb-2">FraudGuard</h1>
            <p class="font-body-sm text-body-sm text-on-surface-variant text-center">Secure your enterprise access</p>
        </div>
        <!-- Login Form -->
        <form class="w-full space-y-6" action="/auth/login" method="POST">
            <!-- Email Field -->
            <div class="space-y-2">
                <label class="font-label-md text-label-md text-on-surface block" for="username">Email</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant" style="font-variation-settings: 'FILL' 0;">mail</span>
                    <input class="w-full input-premium rounded-lg py-3 pl-12 pr-4 font-body-lg text-body-lg text-on-surface" id="username" name="username" placeholder="name@company.com" required="" type="email"/>
                </div>
            </div>
            <!-- Password Field -->
            <div class="space-y-2">
                <div class="flex justify-between items-center">
                    <label class="font-label-md text-label-md text-on-surface block" for="password">Password</label>
                    <a class="font-label-md text-label-md text-primary hover:text-primary-container transition-colors" href="/auth/register">Need an account?</a>
                </div>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant" style="font-variation-settings: 'FILL' 0;">lock</span>
                    <input class="w-full input-premium rounded-lg py-3 pl-12 pr-4 font-body-lg text-body-lg text-on-surface" id="password" name="password" placeholder="••••••••" required="" type="password"/>
                    <button class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-on-surface transition-colors" type="button" onclick="const p = document.getElementById('password'); p.type = p.type === 'password' ? 'text' : 'password';">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">visibility_off</span>
                    </button>
                </div>
            </div>
            <!-- Submit Button -->
            <button class="w-full bg-gradient-to-b from-[#ff8554] to-[#FF6B35] text-white font-title-md text-title-md py-4 rounded-lg shadow-sm hover:shadow-md active:scale-[0.98] transition-all flex items-center justify-center gap-2 mt-4" type="submit">
                Sign In
                <span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 0;">arrow_forward</span>
            </button>

            <!-- Divider -->
            <div class="relative flex py-2 items-center w-full">
                <div class="flex-grow border-t border-outline-variant/30"></div>
                <span class="flex-shrink mx-4 text-xs font-bold text-on-surface-variant uppercase tracking-wider">or</span>
                <div class="flex-grow border-t border-outline-variant/30"></div>
            </div>

            <!-- Google OAuth Button -->
            <button type="button" onclick="openGoogleModal()" class="w-full border border-[#ff6b35]/25 hover:border-[#ff6b35]/50 bg-white/5 hover:bg-[#ff6b35]/5 text-[#ff6b35] font-title-md text-sm py-3.5 rounded-lg active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                <!-- Custom SVG Google Icon -->
                <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                </svg>
                Continue with Google
            </button>
        </form>
    </div>
</main>

<script>
    // Subtle 3D Tilt Effect for Desktop
    document.addEventListener('DOMContentLoaded', () => {
        const card = document.getElementById('loginCard');
        
        // Only apply on non-touch devices
        if (window.matchMedia("(pointer: fine)").matches) {
            document.addEventListener('mousemove', (e) => {
                if (document.body.classList.contains('preloader-active')) return;
                const xAxis = (window.innerWidth / 2 - e.pageX) / 50;
                const yAxis = (window.innerHeight / 2 - e.pageY) / 50;
                
                card.style.transform = `perspective(1000px) rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
            });

            // Reset on mouse leave
            document.addEventListener('mouseleave', () => {
                if (document.body.classList.contains('preloader-active')) return;
                card.style.transform = 'perspective(1000px) rotateY(0deg) rotateX(0deg)';
            });
        }
    });

    // ============================================================
    // PROGRESS LOADER LOGIC (NO THREE.JS / LIGHTWEIGHT SVG ONLY)
    // ============================================================
    (() => {
        let progress = 0;
        const progressCircle = document.getElementById('progressCircle');
        const preloader = document.getElementById('preloader');
        const maxOffset = 816.8;

        function updateProgress() {
            if (progress < 100) {
                progress += Math.floor(Math.random() * 4) + 2;
                if (progress > 100) progress = 100;

                const offset = maxOffset - (progress / 100) * maxOffset;
                progressCircle.style.strokeDashoffset = offset;

                // Dynamic realistic loaded delay intervals
                setTimeout(updateProgress, Math.random() * 30 + 15);
            } else {
                setTimeout(() => {
                    preloader.classList.add('fade-out');
                    document.body.classList.remove('preloader-active');

                    // Smooth reveal of login card
                    const loginCard = document.getElementById('loginCard');
                    if (loginCard) {
                        loginCard.style.opacity = '1';
                        loginCard.style.transform = 'scale(1) translateY(0)';
                    }
                }, 500);
            }
        }

        // Start loading simulation
        setTimeout(updateProgress, 300);
    })();

    // Simulated Google Modal controls
    function openGoogleModal() {
        const modal = document.getElementById('googleSignInModal');
        const card = document.getElementById('googleModalCard');
        modal.classList.remove('opacity-0', 'pointer-events-none');
        card.classList.remove('scale-95');
        card.classList.add('scale-100');
    }

    function closeGoogleModal() {
        const modal = document.getElementById('googleSignInModal');
        const card = document.getElementById('googleModalCard');
        modal.classList.add('opacity-0', 'pointer-events-none');
        card.classList.remove('scale-100');
        card.classList.add('scale-95');
    }

    function selectGoogleAccount(name, email) {
        document.getElementById('googleLoading').classList.remove('hidden');
        document.getElementById('googleLoadingText').innerHTML = `Connecting as <strong>${name}</strong>...`;
        
        setTimeout(() => {
            window.location.href = `/auth/google/signin?name=${encodeURIComponent(name)}&email=${encodeURIComponent(email)}`;
        }, 1200);
    }
</script>

<!-- Beautiful Google Sign-In Modal (Safe Simulated Local Flow) -->
<div id="googleSignInModal" class="fixed inset-0 z-[100] bg-[#0d0d0d]/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div class="bg-white dark:bg-[#121314] rounded-2xl p-8 max-w-[390px] w-full mx-4 shadow-2xl border border-outline-variant/30 dark:border-white/10 transform scale-95 transition-transform duration-300 flex flex-col items-center text-center relative overflow-hidden select-none" id="googleModalCard">
        <!-- Google Logo -->
        <svg class="w-8 h-8 mb-4 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
        </svg>
        <h2 class="text-lg font-bold text-on-surface mb-1 font-headline-lg-mobile">Sign in with Google</h2>
        <p class="text-xs text-on-surface-variant mb-6 font-body-sm">to continue to FraudGuard</p>
        
        <!-- Account List -->
        <div class="w-full space-y-2.5 mb-6">
            <!-- Account 1: Pawan Tiwari -->
            <button onclick="selectGoogleAccount('Pawan Tiwari', 'tiwaripawankumar217@gmail.com')" class="w-full p-3.5 rounded-xl border border-outline-variant/30 hover:border-primary/50 hover:bg-[#ff6b35]/5 transition-all flex items-center gap-3 text-left">
                <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-[#ff8555] to-[#ff6b35] flex items-center justify-center text-white font-bold text-sm shadow-sm select-none shrink-0">
                    P
                </div>
                <div class="overflow-hidden flex-grow">
                    <p class="font-bold text-xs text-on-surface leading-tight">Pawan Tiwari</p>
                    <p class="text-[10px] text-on-surface-variant truncate">tiwaripawankumar217@gmail.com</p>
                </div>
                <span class="material-symbols-outlined text-on-surface-variant text-sm shrink-0">chevron_right</span>
            </button>
            
            <!-- Account 2: Sandbox Demo -->
            <button onclick="selectGoogleAccount('Google (Mock)', 'google_test_user@gmail.com')" class="w-full p-3.5 rounded-xl border border-outline-variant/30 hover:border-primary/50 hover:bg-[#ff6b35]/5 transition-all flex items-center gap-3 text-left">
                <div class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant font-bold text-sm shrink-0">
                    G
                </div>
                <div class="overflow-hidden flex-grow">
                    <p class="font-bold text-xs text-on-surface leading-tight">Google (Mock)</p>
                    <p class="text-[10px] text-on-surface-variant truncate">google_test_user@gmail.com</p>
                </div>
                <span class="material-symbols-outlined text-on-surface-variant text-sm shrink-0">chevron_right</span>
            </button>
        </div>
        
        <!-- Loading overlay -->
        <div id="googleLoading" class="hidden absolute inset-0 bg-[#fcf9f8] dark:bg-[#121314] rounded-2xl flex flex-col items-center justify-center p-6">
            <div class="w-10 h-10 border-4 border-[#ff6b35] border-t-transparent rounded-full animate-spin mb-4"></div>
            <p class="text-xs font-bold text-on-surface" id="googleLoadingText">Connecting to Google...</p>
        </div>
        
        <button onclick="closeGoogleModal()" class="text-xs font-bold text-primary hover:text-primary-container transition-colors">
            Cancel
        </button>
    </div>
</div>
