<% layout('layouts/boilerplate') -%>

<!-- SideNavBar and Mobile TopBar (Partials) -->
<%- include('partials/sidebar') %>

<div class="flex h-screen overflow-hidden w-full">
    <!-- Main Content -->
    <main class="flex-grow ml-0 md:ml-64 pt-24 md:pt-8 pb-24 px-margin-mobile md:px-container-padding max-w-[1440px] mx-auto overflow-y-auto relative">
        
        <!-- Page Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-section-gap gap-4 md:pr-44">
            <div>
                <h1 class="font-display-lg text-display-lg text-on-background mb-2">Transactions</h1>
                <p class="font-body-lg text-body-lg text-on-surface-variant">Monitor, add, and analyze your financial activities.</p>
            </div>
            <div class="flex items-center gap-3">
                <!-- Theme Toggle Pill -->
                <button onclick="toggleTheme()" class="theme-toggle-pill relative flex items-center w-[56px] h-[28px] rounded-full cursor-pointer transition-all duration-300" style="background: rgba(141, 113, 104, 0.15);" title="Toggle Dark/Light Mode" type="button">
                    <span class="sun-icon absolute left-[6px] material-symbols-outlined text-[14px] text-amber-500 transition-opacity duration-300" style="font-variation-settings: 'FILL' 1;">light_mode</span>
                    <span class="moon-icon absolute right-[6px] material-symbols-outlined text-[14px] text-orange-300 transition-opacity duration-300" style="font-variation-settings: 'FILL' 1;">dark_mode</span>
                    <span class="theme-knob absolute left-[3px] w-[22px] h-[22px] rounded-full bg-white shadow-md transition-transform duration-300"></span>
                </button>
            </div>
        </div>

        <!-- Server-side Error Banner -->
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-6 p-4 rounded-xl bg-error-container/30 border border-error/30 flex items-start gap-3">
            <span class="material-symbols-outlined text-error mt-0.5" style="font-variation-settings: 'FILL' 1;">error</span>
            <div>
                <% if (error === 'insufficient_balance') { %>
                    <p class="font-semibold text-error">Insufficient Balance</p>
                    <p class="text-sm text-on-surface-variant mt-0.5">
                        This expense was blocked. Your monthly income is $<%= typeof income !== 'undefined' && income ? income : '0' %>.
                        You only have $<%= typeof remaining !== 'undefined' && remaining ? remaining : '0' %> remaining.
                        Add income first before recording this expense.
                    </p>
                <% } else if (error === 'zero_income') { %>
                    <p class="font-semibold text-error">Zero Income</p>
                    <p class="text-sm text-on-surface-variant mt-0.5">
                        You cannot record expenses because your monthly income is $0. Please add an income transaction first.
                    </p>
                <% } else if (error === 'zero_budget') { %>
                    <p class="font-semibold text-error">Zero Budget</p>
                    <p class="text-sm text-on-surface-variant mt-0.5">
                        Your budget is $0. You must set a budget in the Budgets tab before recording expenses.
                    </p>
                <% } else if (error === 'budget_exceeded') { %>
                    <p class="font-semibold text-error">Budget Exceeded</p>
                    <p class="text-sm text-on-surface-variant mt-0.5">
                        This expense would exceed your monthly budget of $<%= typeof budget !== 'undefined' && budget ? budget : '0' %>. 
                        Please increase your budget before recording this expense.
                    </p>
                <% } %>
            </div>
            <button onclick="this.parentElement.remove()" class="ml-auto text-on-surface-variant hover:text-on-surface">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
        <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter w-full">
            <!-- New Transaction Entry Card (Left Column) -->
            <div class="lg:col-span-4 flex flex-col gap-gutter w-full">
                <!-- AI Quick Ingest Card -->
                <div class="glass-card rounded-xl p-container-padding relative overflow-hidden hover-lift">
                    <div class="absolute inset-0 bg-gradient-to-r from-primary/5 to-transparent pointer-events-none"></div>
                    <h2 class="font-title-md text-title-md text-on-surface mb-3 flex items-center gap-2 relative z-10">
                        <span class="material-symbols-outlined text-primary animate-pulse">input_circle</span>
                        AI Quick Ingest (SMS / UPI)
                    </h2>
                    <p class="text-xs text-on-surface-variant mb-4">Paste your bank SMS or UPI notification to auto-populate the transaction form instantly!</p>
                    <div class="flex flex-col gap-3">
                        <textarea id="quick-ingest-text" rows="2" class="w-full input-premium rounded-lg px-3 py-2 text-xs text-on-surface placeholder-outline focus:ring-0" placeholder="e.g. Sent $45.00 to Reliance Mart for Groceries on 2026-05-25"></textarea>
                        <button onclick="parseQuickIngest()" type="button" class="btn-primary text-white text-xs font-semibold py-2.5 rounded-lg flex items-center justify-center gap-1">
                            <span class="material-symbols-outlined text-[16px]">psychology</span>
                            Analyze & Populate Form
                        </button>
                    </div>
                </div>

                <!-- Batch Statement Upload Card -->
                <div class="glass-card rounded-xl p-container-padding relative overflow-hidden mt-gutter hover-lift">
                    <div class="absolute inset-0 bg-gradient-to-r from-tertiary-container/5 to-transparent pointer-events-none"></div>
                    <h2 class="font-title-md text-title-md text-on-surface mb-3 flex items-center gap-2 relative z-10">
                        <span class="material-symbols-outlined text-tertiary animate-pulse">cloud_upload</span>
                        Document & Statement Ingest
                    </h2>
                    <p class="text-xs text-on-surface-variant mb-4">Upload a CSV, PDF, or statement/receipt Image to dynamically analyze and ingest multiple transactions instantly!</p>
                    
                    <div class="flex flex-col gap-3">
                        <div id="upload-dropzone" class="border-2 border-dashed border-outline-variant/30 rounded-lg p-6 text-center cursor-pointer hover:border-primary/50 transition-all duration-300 relative flex flex-col items-center justify-center gap-2" onclick="document.getElementById('statement-file-input').click()">
                            <div class="w-12 h-12 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant shadow-inner transition-transform duration-300 transform" id="upload-icon-wrapper">
                                <span class="material-symbols-outlined text-[28px]" id="upload-icon">upload_file</span>
                            </div>
                            <div>
                                <p class="text-[11px] text-on-surface font-semibold" id="upload-text">Click or drag & drop file here</p>
                                <p class="text-[9px] text-on-surface-variant mt-0.5" id="upload-subtext">Supports: CSV, PDF, Images (PNG, JPG, JPEG)</p>
                            </div>
                            <input id="statement-file-input" type="file" accept=".csv,.pdf,image/*" class="hidden" onchange="handleFileSelect(event)"/>
                        </div>
                        <div id="file-ingest-progress" class="hidden flex flex-col gap-1.5 p-3 rounded-lg bg-surface-container/60 border border-outline-variant/20">
                            <div class="flex justify-between items-center text-[10px] font-semibold text-primary">
                                <span id="progress-status">Analyzing file...</span>
                                <span id="progress-percentage">0%</span>
                            </div>
                            <div class="w-full bg-outline-variant/20 h-1.5 rounded-full overflow-hidden">
                                <div id="progress-bar-fill" class="bg-primary h-full w-0 transition-all duration-300"></div>
                            </div>
                        </div>
                        <div id="csv-file-info" class="hidden text-[10px] text-primary font-semibold flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">check_circle</span>
                            <span id="csv-filename">filename.csv</span>
                        </div>
                        <button id="btn-upload-csv" onclick="processSelectedFile()" type="button" disabled class="btn-primary text-white text-xs font-semibold py-2.5 rounded-lg flex items-center justify-center gap-1 opacity-50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[16px]">analytics</span>
                            Analyze & Ingest
                        </button>
                    </div>
                </div>

                <div class="glass-card rounded-xl p-container-padding hover-lift">
                    <h2 class="font-title-md text-title-md text-on-surface mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">add_circle</span>
                        New Entry
                    </h2>
                    
                    <form action="/transactions" method="POST" class="flex flex-col gap-4">
                        <!-- Merchant / Description -->
                        <div>
                            <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="description">Description / Merchant</label>
                            <input class="w-full input-premium rounded-lg px-4 py-3 font-body-lg text-body-lg text-on-surface placeholder-outline focus:ring-0" id="description" name="description" placeholder="e.g. AWS Cloud Hosting" required type="text"/>
                        </div>

                        <!-- Amount -->
                        <div>
                            <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="amount">Amount (USD)</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant material-symbols-outlined" style="font-size: 18px;">attach_money</span>
                                <input class="w-full input-premium rounded-lg pl-10 pr-4 py-3 font-body-lg text-body-lg text-on-surface focus:ring-0" id="amount" name="amount" placeholder="0.00" step="0.01" min="0.01" required type="number"/>
                            </div>
                        </div>

                        <!-- Type (Income vs Expense) -->
                        <div>
                            <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="type">Transaction Type</label>
                            <select class="w-full input-premium rounded-lg px-4 py-3 font-body-lg text-body-lg text-on-surface focus:ring-0 appearance-none" id="type" name="type" required>
                                <option value="expense">Expense</option>
                                <option value="income">Income</option>
                            </select>
                        </div>

                        <!-- Category -->
                        <div>
                            <label class="font-label-md text-label-md text-on-surface-variant block mb-1 uppercase tracking-wider" for="category">Category</label>
                            <select class="w-full input-premium rounded-lg px-4 py-3 font-body-lg text-body-lg text-on-surface focus:ring-0 appearance-none" id="category" name="category" required>
                                <option disabled selected value="">Select Category</option>
                                <option value="Groceries">Groceries</option>
                                <option value="Rent">Rent</option>
                                <option value="Entertainment">Entertainment</option>
                                <option value="Transfer">Transfer</option>
                                <option value="Salary">Salary</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <!-- Submit Button -->
                        <button class="btn-primary text-white font-title-md text-body-lg rounded-lg py-4 mt-4 flex items-center justify-center gap-2 transition-all w-full" type="submit">
                            <span class="material-symbols-outlined text-sm">add</span>
                            Add Record
                        </button>
                    </form>
                </div>

                <!-- Quick Stats: Flagged Count -->
                <div class="glass-card rounded-xl p-container-padding flex items-center justify-between">
                    <div>
                        <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Flagged Transactions</p>
                        <p class="font-headline-lg text-headline-lg text-secondary">
                            <%= (typeof transactions !== 'undefined') ? transactions.filter(t => t.isFlagged).length : '0' %>
                        </p>
                    </div>
                    <div class="w-12 h-12 rounded-full bg-error-container flex items-center justify-center text-error">
                        <span class="material-symbols-outlined">warning</span>
                    </div>
                </div>
            </div>

            <!-- Recent Activity Table (Right Column) -->
            <div class="lg:col-span-8 w-full">
                <div class="glass-card rounded-xl h-full flex flex-col w-full hover-lift">
                    <!-- Table Header Controls -->
                    <div class="p-container-padding border-b border-outline-variant/30 flex justify-between items-center w-full">
                        <h2 class="font-title-md text-title-md text-on-surface">Recent Activity</h2>
                        <div class="flex gap-2">
                            <button class="p-2 rounded-lg bg-surface-container-low text-on-surface-variant hover:bg-surface-container transition-colors border border-outline-variant/50">
                                <span class="material-symbols-outlined text-sm">filter_list</span>
                            </button>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant material-symbols-outlined text-sm">search</span>
                                <input class="input-premium rounded-lg pl-9 pr-4 py-2 font-body-sm text-body-sm w-48 focus:w-64 transition-all" id="tableSearch" placeholder="Search..." type="text" onkeyup="filterTable()"/>
                            </div>
                        </div>
                    </div>

                    <!-- Scrollable Table -->
                    <div class="overflow-x-auto flex-grow w-full">
                        <table class="w-full text-left border-collapse" id="txnTable">
                            <thead>
                                <tr class="bg-surface-container-lowest/50 border-b border-outline-variant/30">
                                    <th class="py-4 px-6 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Date & Time</th>
                                    <th class="py-4 px-6 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Description</th>
                                    <th class="py-4 px-6 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Category</th>
                                    <th class="py-4 px-6 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-right">Amount</th>
                                    <th class="py-4 px-6 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-center">Status</th>
                                    <th class="py-4 px-6 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="font-body-sm text-body-sm text-on-surface divide-y divide-outline-variant/20">
                                <% if (typeof transactions !== 'undefined' && transactions.length > 0) { %>
                                    <% transactions.forEach(function(txn) { %>
                                        <!-- Row -->
                                        <tr class="<%= txn.isFlagged ? 'border-l-2 border-l-error bg-error-container/5 hover:bg-error-container/10' : '' %>" id="row-<%= txn._id %>">
                                            <td class="py-4 px-6">
                                                <%= new Date(txn.date).toLocaleDateString('en-US', {month: 'short', day: 'numeric'}) %> 
                                                <span class="text-xs text-on-surface-variant ml-1"><%= new Date(txn.date).toLocaleTimeString('en-US', {hour: '2-digit', minute:'2-digit', hour12: false}) %></span>
                                            </td>
                                            <td class="py-4 px-6 font-medium">
                                                <%= txn.description %>
                                            </td>
                                            <td class="py-4 px-6">
                                                <span class="px-2.5 py-1 rounded bg-surface-container-high/60 text-xs"><%= txn.category %></span>
                                            </td>
                                            <td class="py-4 px-6 text-right font-medium <%= txn.type === 'income' ? 'text-green-600' : 'text-secondary' %>">
                                                <%= txn.type === 'income' ? '+' : '-' %>$<%= parseFloat(txn.amount).toLocaleString(undefined, {minimumFractionDigits: 2}) %>
                                            </td>
                                            <td class="py-4 px-6 text-center">
                                                <% if (txn.isFlagged) { %>
                                                    <button onclick="toggleDrawer('<%= txn._id %>')" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-error-container text-error text-xs font-semibold border border-error/20 hover:scale-105 active:scale-95 transition-all">
                                                        <span class="material-symbols-outlined text-[14px]">warning</span> Flagged
                                                    </button>
                                                <% } else { %>
                                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-surface-container text-on-surface text-xs font-medium border border-outline-variant/50">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Cleared
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td class="py-4 px-6 text-right">
                                                <div class="flex items-center justify-end gap-2">
                                                    <% if (txn.isFlagged) { %>
                                                        <button onclick="toggleDrawer('<%= txn._id %>')" class="text-primary hover:text-primary-container transition-colors" title="Review ML Assessment">
                                                            <span class="material-symbols-outlined text-sm">fact_check</span>
                                                        </button>
                                                    <% } %>
                                                    <!-- Simple form delete -->
                                                    <form action="/transactions/<%= txn._id %>?_method=DELETE" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this transaction?')">
                                                        <button type="submit" class="text-on-surface-variant hover:text-secondary transition-colors" title="Delete">
                                                            <span class="material-symbols-outlined text-sm">delete</span>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <!-- Collapsible Drawer for flagged reasons (SHAP values) -->
                                        <% if (txn.isFlagged) { %>
                                            <tr id="drawer-<%= txn._id %>" class="hidden bg-error-container/5">
                                                <td colspan="6" class="py-4 px-8 border-l-2 border-l-error">
                                                    <div class="flex flex-col gap-2">
                                                        <div class="flex items-center gap-2 text-error font-semibold text-xs">
                                                            <span class="material-symbols-outlined text-sm">security</span>
                                                            ML SERVICE RISK ANALYSIS (Isolation Forest Anomaly Score: <%= (txn.fraudScore * 100).toFixed(1) %>%)
                                                        </div>
                                                        <div class="text-xs text-on-surface-variant space-y-1.5 pl-6">
                                                            <% if (txn.flagReasons && txn.flagReasons.length > 0) { %>
                                                                <% txn.flagReasons.forEach(function(reason) { %>
                                                                    <div>• <%= reason %></div>
                                                                <% }) %>
                                                            <% } else { %>
                                                                <div>• Multi-dimensional spending anomaly detected.</div>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% } %>
                                    <% }) %>
                                <% } else { %>
                                    <!-- Empty State -->
                                    <tr>
                                        <td colspan="6" class="py-12 text-center text-on-surface-variant">
                                            <span class="material-symbols-outlined text-4xl block mb-2 text-outline-variant">account_balance_wallet</span>
                                            No transactions loaded. Add your first record to begin security monitoring!
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Budget Warning Modal -->
<div id="budgetWarningModal" class="fixed inset-0 z-[100] bg-[#0d0d0d]/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div class="glass-card rounded-2xl p-8 max-w-[500px] w-full mx-4 transform scale-95 transition-transform duration-300" id="warningModalCard">
        <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-error-container flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-error text-3xl" style="font-variation-settings: 'FILL' 1;">warning</span>
            </div>
            <div>
                <h3 id="warningModalTitle" class="font-title-md text-title-md text-on-background">Warning</h3>
                <p class="font-body-sm text-body-sm text-on-surface-variant">Review before proceeding</p>
            </div>
        </div>
        <div id="warningModalBody" class="space-y-3 mb-8"></div>
        <div class="flex gap-3">
            <button onclick="dismissWarning()" class="flex-1 py-3 border border-outline-variant rounded-xl font-label-md text-label-md text-on-surface-variant hover:bg-surface-container transition-colors">
                Cancel
            </button>
            <button onclick="proceedAnyway()" id="proceedBtn" class="flex-1 py-3 bg-secondary text-on-secondary rounded-xl font-label-md text-label-md hover:bg-secondary/90 transition-colors flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">add_circle</span>
                Add Anyway
            </button>
        </div>
    </div>
</div>

<!-- Ingest Review & Verification Modal -->
<div id="ingestReviewModal" class="fixed inset-0 z-[100] bg-[#0d0d0d]/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div class="glass-card rounded-2xl p-6 max-w-[850px] w-full mx-4 max-h-[85vh] flex flex-col transform scale-95 transition-transform duration-300" id="ingestReviewCard">
        <div class="flex items-center justify-between mb-4 border-b border-outline-variant/30 pb-3">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-2xl">rate_review</span>
                </div>
                <div>
                    <h3 class="font-title-md text-title-md text-on-background">Verify Extracted Transactions</h3>
                    <p id="ingestReviewSubtitle" class="font-body-xs text-xs text-on-surface-variant">We found X transactions. Adjust fields below if needed before ingesting.</p>
                </div>
            </div>
            <button onclick="dismissIngestReview()" class="text-on-surface-variant hover:text-on-surface">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <!-- Editable Transactions Table -->
        <div class="overflow-y-auto flex-grow mb-6 pr-2 max-h-[50vh]">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-outline-variant/20">
                        <th class="py-2.5 px-3 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-xs">Date</th>
                        <th class="py-2.5 px-3 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-xs">Description</th>
                        <th class="py-2.5 px-3 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-xs">Category</th>
                        <th class="py-2.5 px-3 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-xs">Type</th>
                        <th class="py-2.5 px-3 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-xs text-right">Amount ($)</th>
                        <th class="py-2.5 px-3 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-xs text-right">Action</th>
                    </tr>
                </thead>
                <tbody id="ingestReviewTableBody" class="font-body-sm text-body-sm text-on-surface divide-y divide-outline-variant/10">
                    <!-- Rows injected via JS -->
                </tbody>
            </table>
        </div>
        
        <div class="flex justify-between items-center gap-3 pt-3 border-t border-outline-variant/30">
            <span id="ingestModalSummary" class="text-xs text-on-surface-variant font-medium">Total: 0 transactions</span>
            <div class="flex gap-3">
                <button onclick="dismissIngestReview()" class="px-5 py-2.5 border border-outline-variant rounded-xl font-label-md text-label-md text-on-surface-variant hover:bg-surface-container transition-colors text-xs">
                    Cancel
                </button>
                <button onclick="confirmIngestUpload()" id="btn-confirm-ingest" class="px-5 py-2.5 bg-primary text-white rounded-xl font-label-md text-label-md hover:bg-primary/95 transition-colors flex items-center justify-center gap-2 text-xs font-semibold">
                    <span class="material-symbols-outlined text-[16px]">done_all</span>
                    Ingest Verified Records
                </button>
            </div>
        </div>
    </div>
</div>


<!-- Mobile Bottom NavBar (Partial) -->
<%- include('partials/mobile_nav') %>

<script>
    let _pendingForm = null;

    // Intercept transaction form submission for client-side budget/balance check
    const txnForm = document.querySelector('form[action="/transactions"]');
    if (txnForm) {
        txnForm.addEventListener('submit', async function(e) {
            const type = document.getElementById('type').value;
            if (type !== 'expense') return; // Only check expenses

            e.preventDefault();
            _pendingForm = this;

            try {
                const res = await fetch('/transactions/budget-info');
                const data = await res.json();

                const amount = parseFloat(document.getElementById('amount').value) || 0;
                const category = document.getElementById('category').value;
                const warnings = [];

                // Check 1: Would total expenses exceed monthly income?
                if (data.totalIncome > 0) {
                    const newExpenseTotal = data.totalExpenses + amount;
                    if (newExpenseTotal > data.totalIncome) {
                        warnings.push({
                            title: 'Insufficient Balance',
                            message: `Add the income to continue expense. (Expense exceeds income by $${(newExpenseTotal - data.totalIncome).toFixed(2)})`
                        });
                    }
                }

                // Check 2: Would this exceed the global budget or is budget 0?
                if (warnings.length === 0) {
                    if (data.globalBudget === 0) {
                        warnings.push({
                            title: 'Budget is Zero',
                            message: `Budget is 0. No expense can occur. Please increase budget to do more expense.`
                        });
                    } else {
                        const newExpenseTotal = data.totalExpenses + amount;
                        if (newExpenseTotal > data.globalBudget) {
                            warnings.push({
                                title: 'Budget Exceeded',
                                message: `It is exceed. Increase budget to do more expense. (Expense exceeds budget by $${(newExpenseTotal - data.globalBudget).toFixed(2)})`
                            });
                        }
                    }
                }

                if (warnings.length > 0) {
                    showWarningModal(warnings);
                } else {
                    _pendingForm = null;
                    this.submit();
                }
            } catch (err) {
                // If API call fails, just submit normally
                _pendingForm = null;
                this.submit();
            }
        });
    }

