    function loadScript(url) {
        return new Promise((resolve, reject) => {
            const existing = document.querySelector(`script[src="${url}"]`);
            if (existing) {
                if (window.pdfjsLib || window.Tesseract) return resolve();
                existing.addEventListener('load', resolve);
                existing.addEventListener('error', reject);
                return;
            }
            const script = document.createElement('script');
            script.src = url;
            script.onload = resolve;
            script.onerror = reject;
            document.head.appendChild(script);
        });
    }

    async function parsePDFText(file, onProgress) {
        onProgress('Loading PDF engine...', 10);
        if (typeof pdfjsLib === 'undefined') {
            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        }

        onProgress('Reading PDF pages...', 25);
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        let text = "";

        const numPages = pdf.numPages;
        for (let i = 1; i <= numPages; i++) {
            onProgress(`Reading page ${i} of ${numPages}...`, 25 + Math.floor((i / numPages) * 50));
            const page = await pdf.getPage(i);
            const content = await page.getTextContent();
            const pageText = content.items.map(item => item.str).join(" ");
            text += pageText + "\n";
        }

        onProgress('Analyzing extracted text...', 90);
        return text;
    }

    async function parseImageText(file, onProgress) {
        onProgress('Loading OCR engine...', 10);
        if (typeof Tesseract === 'undefined') {
            await loadScript('https://cdnjs.cloudflare.com/ajax/libs/tesseract.js/4.1.1/tesseract.min.js');
        }

        onProgress('Initializing recognition...', 25);
        const result = await Tesseract.recognize(file, 'eng', {
            logger: m => {
                if (m.status === 'recognizing text') {
                    onProgress(`Running OCR: ${Math.floor(m.progress * 100)}%`, 25 + Math.floor(m.progress * 60));
                }
            }
        });

        onProgress('Parsing receipt/statement text...', 95);
        return result.data.text;
    }

    function extractTransactionsFromText(text) {
        const lines = text.split('\n');
        const transactions = [];

        // Dates: e.g. 2026-05-25, 05/25/2026, May 25, 25-May-2026, 25.05.2026
        const datePattern = /(?:\d{4}[-/]\d{1,2}[-/]\d{1,2}|\d{1,2}[-/.]\d{1,2}[-/.]\d{2,4}|(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]* \d{1,2}|\d{1,2} (?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*)/i;

        // Amounts: e.g. $1,234.56, -45.00, 12.34
        const amountPattern = /(?:[\$\€\£\¥]|rs\.?|inr)?\s*(-?\d{1,3}(?:,\d{3})*(?:\.\d{2}))\b/;

        for (let line of lines) {
            line = line.trim();
            if (!line || line.length < 5) continue;

            const amtMatch = line.match(amountPattern);
            if (!amtMatch) continue;

            const rawAmount = amtMatch[1].replace(/,/g, '');
            const amount = Math.abs(parseFloat(rawAmount));
            if (isNaN(amount) || amount === 0) continue;

            let date = new Date().toISOString().split('T')[0]; // Default to today
            const dateMatch = line.match(datePattern);
            if (dateMatch) {
                try {
                    const parsedDate = new Date(dateMatch[0].replace(/\./g, '/'));
                    if (!isNaN(parsedDate.getTime())) {
                        date = parsedDate.toISOString().split('T')[0];
                    }
                } catch (e) {}
            }

            let type = 'expense';
            if (line.toLowerCase().match(/(credit|received|deposit|salary|refund|inflow|\+)/i)) {
                if (!line.toLowerCase().match(/(debit|payment|spent|\-)/i)) {
                    type = 'income';
                }
            }

            // Extract description by removing date and amount
            let description = line
                .replace(amtMatch[0], '')
                .replace(dateMatch ? dateMatch[0] : '', '')
                .replace(/(?:ref|uuid|tx|transaction|id|card|auth|pos|terminal|statement|bank|balance|chk|check)\b/gi, '')
                .replace(/[-*#:=_]/g, ' ')
                .replace(/\s+/g, ' ')
                .trim();

            if (description.length < 2) {
                description = type === 'income' ? 'Ingested Income' : 'Ingested Expense';
            }

            // Category classification
            let category = 'Other';
            const lowercaseDesc = description.toLowerCase();
            if (lowercaseDesc.match(/(grocery|mart|reliance|food|walmart|groceries|supermarket|vegetable|milk)/i)) {
                category = 'Groceries';
            } else if (lowercaseDesc.match(/(rent|landlord|flat|apartment|lease|maintenance)/i)) {
                category = 'Rent';
            } else if (lowercaseDesc.match(/(movie|netflix|ticket|cinema|fun|game|entertainment|play|show)/i)) {
                category = 'Entertainment';
            } else if (lowercaseDesc.match(/(transfer|upi|sent\s+to|paytm|gpay|ref|reference)/i)) {
                category = 'Transfer';
            } else if (lowercaseDesc.match(/(salary|paycheck|credit|salary|dividend|pension)/i)) {
                category = 'Salary';
            }

            transactions.push({
                description,
                amount,
                category,
                type,
                date
            });
        }

        return transactions;
    }

    function handleFileSelect(event) {
        const file = event.target.files[0];
        if (!file) return;

        selectedFile = file;

        // Visual display updates
        document.getElementById('csv-filename').textContent = file.name;
        document.getElementById('csv-file-info').classList.remove('hidden');

        // Update the dropzone text/icon
        const ext = file.name.split('.').pop().toLowerCase();
        let icon = 'upload_file';
        if (ext === 'csv') icon = 'description';
        else if (ext === 'pdf') icon = 'picture_as_pdf';
        else if (['png', 'jpg', 'jpeg', 'gif', 'webp'].includes(ext)) icon = 'image';

        document.getElementById('upload-icon').textContent = icon;
        document.getElementById('upload-text').textContent = file.name;
        document.getElementById('upload-subtext').textContent = `${(file.size / 1024).toFixed(1)} KB • Click or drag to replace`;

        // Enable action button
        const btn = document.getElementById('btn-upload-csv');
        btn.disabled = false;
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
        btn.innerHTML = `<span class="material-symbols-outlined text-[16px]">analytics</span> Analyze & Ingest`;
    }

    function getFileBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => {
                const base64String = reader.result.split(',')[1];
                resolve(base64String);
            };
            reader.onerror = error => reject(error);
        });
    }

    async function processSelectedFile() {
        if (!selectedFile) return;

        const btn = document.getElementById('btn-upload-csv');
        const progressContainer = document.getElementById('file-ingest-progress');
        const progressStatus = document.getElementById('progress-status');
        const progressBarFill = document.getElementById('progress-bar-fill');
        const progressPercentage = document.getElementById('progress-percentage');

        btn.disabled = true;
        btn.classList.add('opacity-50', 'cursor-not-allowed');
        progressContainer.classList.remove('hidden');

        const updateProgress = (status, percent) => {
            progressStatus.textContent = status;
            progressBarFill.style.width = `${percent}%`;
            progressPercentage.textContent = `${percent}%`;
        };

        const ext = selectedFile.name.split('.').pop().toLowerCase();
        parsedTransactions = [];

        try {
            if (ext === 'csv') {
                updateProgress('Reading CSV file...', 20);
                const reader = new FileReader();
                reader.onload = async function(e) {
                    const text = e.target.result;
                    updateProgress('Analyzing CSV with Gemini AI...', 50);
                    try {
                        const res = await fetch('/transactions/parse-file', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ text })
                        });
                        const data = await res.json();
                        if (!data.success) throw new Error(data.error || "Gemini parsing failed");

                        parsedTransactions = data.transactions;
                        updateProgress('Done!', 100);
                        setTimeout(() => {
                            progressContainer.classList.add('hidden');
                            btn.disabled = false;
                            btn.classList.remove('opacity-50', 'cursor-not-allowed');
                            if (parsedTransactions.length > 0) {
                                showIngestReview(parsedTransactions);
                            } else {
                                alert('No valid transactions found in CSV file.');
                            }
                        }, 500);
                    } catch (err) {
                        alert("Gemini CSV parsing error: " + err.message);
                        progressContainer.classList.add('hidden');
                        btn.disabled = false;
                        btn.classList.remove('opacity-50', 'cursor-not-allowed');
                    }
                };
                reader.readAsText(selectedFile);
                return;

            } else if (ext === 'pdf') {
                updateProgress('Reading PDF text layers...', 20);
                const text = await parsePDFText(selectedFile, (status, percent) => {
                    updateProgress(status, 10 + Math.floor(percent * 0.4));
                });
                
                updateProgress('Analyzing PDF with Gemini AI...', 60);
                const res = await fetch('/transactions/parse-file', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text })
                });
                const data = await res.json();
                if (!data.success) throw new Error(data.error || "Gemini parsing failed");

                parsedTransactions = data.transactions;

            } else if (['png', 'jpg', 'jpeg', 'webp', 'gif'].includes(ext)) {
                updateProgress('Converting image data...', 20);
                const base64 = await getFileBase64(selectedFile);
                let mimeType = selectedFile.type || 'image/jpeg';
                
                updateProgress('Analyzing image visually with Gemini AI...', 50);
                const res = await fetch('/transactions/parse-file', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ base64, mimeType })
                });
                const data = await res.json();
                if (!data.success) throw new Error(data.error || "Gemini parsing failed");

                parsedTransactions = data.transactions;

            } else {
                alert('Unsupported file format. Please upload CSV, PDF or Image.');
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                progressContainer.classList.add('hidden');
                return;
            }

            updateProgress('Done!', 100);
            setTimeout(() => {
                progressContainer.classList.add('hidden');
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                if (parsedTransactions.length > 0) {
                    showIngestReview(parsedTransactions);
                } else {
                    alert('Could not extract any transactions from this document. Please verify layout or try manual entry.');
                }
            }, 500);

        } catch (err) {
            console.error("Error during document parsing:", err);
            alert("Error processing file: " + err.message);
            updateProgress('Failed', 0);
            setTimeout(() => {
                progressContainer.classList.add('hidden');
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
            }, 1000);
        }
    }


