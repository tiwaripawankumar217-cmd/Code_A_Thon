            <tr id="review-row-${idx}" class="hover:bg-surface-container/30 transition-colors">
                <td class="py-2 px-1">
                    <input type="date" value="${t.date}" class="w-full bg-surface-container-low border border-outline-variant/30 rounded px-2 py-1 text-xs text-on-surface focus:outline-none focus:border-primary" onchange="updateReviewField(${idx}, 'date', this.value)" />
                </td>
                <td class="py-2 px-1">
                    <input type="text" value="${escapeHtml(t.description)}" class="w-full bg-surface-container-low border border-outline-variant/30 rounded px-2 py-1 text-xs text-on-surface focus:outline-none focus:border-primary font-medium" onchange="updateReviewField(${idx}, 'description', this.value)" />
                </td>
                <td class="py-2 px-1">
                    <select class="w-full bg-surface-container-low border border-outline-variant/30 rounded px-2 py-1 text-xs text-on-surface focus:outline-none focus:border-primary" onchange="updateReviewField(${idx}, 'category', this.value)">
                        <option value="Groceries" ${t.category === 'Groceries' ? 'selected' : ''}>Groceries</option>
                        <option value="Rent" ${t.category === 'Rent' ? 'selected' : ''}>Rent</option>
                        <option value="Entertainment" ${t.category === 'Entertainment' ? 'selected' : ''}>Entertainment</option>
                        <option value="Transfer" ${t.category === 'Transfer' ? 'selected' : ''}>Transfer</option>
                        <option value="Salary" ${t.category === 'Salary' ? 'selected' : ''}>Salary</option>
                        <option value="Other" ${t.category === 'Other' ? 'selected' : ''}>Other</option>
                    </select>
                </td>
                <td class="py-2 px-1">
                    <select class="w-full bg-surface-container-low border border-outline-variant/30 rounded px-2 py-1 text-xs text-on-surface focus:outline-none focus:border-primary" onchange="updateReviewField(${idx}, 'type', this.value)">
                        <option value="expense" ${t.type === 'expense' ? 'selected' : ''}>Expense</option>
                        <option value="income" ${t.type === 'income' ? 'selected' : ''}>Income</option>
                    </select>
                </td>
                <td class="py-2 px-1 text-right">
                    <input type="number" step="0.01" min="0.01" value="${t.amount.toFixed(2)}" class="w-24 text-right bg-surface-container-low border border-outline-variant/30 rounded px-2 py-1 text-xs text-on-surface focus:outline-none focus:border-primary" onchange="updateReviewField(${idx}, 'amount', parseFloat(this.value) || 0)" />
                </td>
                <td class="py-2 px-1 text-center">
                    <button type="button" class="text-on-surface-variant hover:text-error transition-colors p-1" onclick="deleteReviewRow(${idx})" title="Remove item">
                        <span class="material-symbols-outlined text-sm">delete</span>
                    </button>
                </td>
            </tr>
        `).join('');

        summary.textContent = `Total: ${transactions.length} transactions`;
    }

    function updateReviewField(idx, field, value) {
        if (parsedTransactions[idx]) {
            parsedTransactions[idx][field] = value;
        }
    }

    function deleteReviewRow(idx) {
        parsedTransactions.splice(idx, 1);
        renderReviewRows(parsedTransactions);
        showReviewSubtitle(parsedTransactions.length);
    }

    function escapeHtml(str) {
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    async function confirmIngestUpload() {
        if (parsedTransactions.length === 0) {
            alert("No transactions to import!");
            return;
        }

        const btn = document.getElementById('btn-confirm-ingest');
        btn.disabled = true;
        btn.innerHTML = `<span class="material-symbols-outlined text-[16px] animate-spin">sync</span> Ingesting records...`;

        try {
            const res = await fetch('/transactions/upload', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ transactions: parsedTransactions })
            });

            const data = await res.json();
            if (data.success) {
                dismissIngestReview();
                
                const toast = document.createElement('div');
                toast.className = 'fixed top-4 right-4 z-50 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg slide-in font-semibold';
                toast.textContent = `Successfully processed and queued ${data.count} transactions!`;
                document.body.appendChild(toast);
                
                setTimeout(() => {
                    toast.remove();
                    window.location.reload();
                }, 1500);
            } else {
                throw new Error(data.error || "Server responded with failure");
            }
        } catch (err) {
            console.error("[Ingest Upload] Failed:", err);
            alert("Failed to ingest transactions: " + err.message);
            btn.disabled = false;
            btn.innerHTML = `<span class="material-symbols-outlined text-[16px]">done_all</span> Ingest Verified Records`;
        }
    }

    document.addEventListener('mousemove', (e) => {
        const orbs = document.querySelectorAll('.ambient-orb');
        if (orbs.length >= 2) {
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            orbs[0].style.transform = `translate(${x * 20}px, ${y * 20}px)`;
            orbs[1].style.transform = `translate(${x * -30}px, ${y * -30}px)`;
        }
    });
</script>
